@using Wombat.Domain.Identity

<div class="top-row ps-3 navbar navbar-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="">
      <img class="navbar-brand-mark" src="/brand/wombat-mark.svg" alt="" width="40" height="40" />
      <span class="navbar-brand-text">Wombat</span>
    </a>
  </div>
</div>

<input type="checkbox" title="Navigation menu" aria-label="Toggle navigation menu"
       aria-expanded="@IsNavMenuExpanded" class="navbar-toggler" @bind="IsNavMenuExpanded" />

<div class="nav-scrollable" @onclick="CloseNavMenu">
  <nav class="flex-column">
    <div class="nav-item px-3">
      <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
        <Icon Name="home" />
        Home
      </NavLink>
    </div>

    <AuthorizeView Context="navAuth">
      <Authorized Context="navUser">
        <div class="nav-item px-3">
          <NavLink class="nav-link" href="/account/profile">
            <Icon Name="user" />
            My Account
          </NavLink>
        </div>
        <div class="nav-item px-3">
          <NavLink class="nav-link" href="/account/data-rights">
            <Icon Name="shield" />
            Data Rights
          </NavLink>
        </div>

        <AuthorizeView Roles="@($"{WombatRoles.Trainee},{WombatRoles.PendingTrainee}")" Context="traineeAuth">
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/activities/new">
              <Icon Name="calendar" />
              Activities
            </NavLink>
          </div>
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/activities/mine">
              <Icon Name="file-text" />
              My Activities
            </NavLink>
          </div>
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/msf/my-reports">
              <Icon Name="file-text" />
              MSF Reports
            </NavLink>
          </div>
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/committee/my-reviews">
              <Icon Name="file-text" />
              Committee Reviews
            </NavLink>
          </div>
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/placeholder/my-curriculum">
              <Icon Name="book" />
              My Curriculum
            </NavLink>
          </div>
        </AuthorizeView>

        <AuthorizeView Roles="@WombatRoles.Assessor" Context="assessorAuth">
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/activities/inbox">
              <Icon Name="inbox" />
              Activity Inbox
            </NavLink>
          </div>
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/placeholder/recent-activities">
              <Icon Name="file-text" />
              Recent Activities
            </NavLink>
          </div>
