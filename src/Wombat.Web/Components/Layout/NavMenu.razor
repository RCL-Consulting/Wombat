        <AuthorizeView Roles="@WombatRoles.Coordinator" Context="coordinatorAuth">
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/admin/invitations">
              <Icon Name="users" />
              Invitations
            </NavLink>
          </div>
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/admin/data-rights">
              <Icon Name="shield" />
