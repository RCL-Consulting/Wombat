              <Icon Name="file-text" />
              Committee Reviews
            </NavLink>
          </div>
          <div class="nav-item px-3">
            <NavLink class="nav-link" href="/placeholder/stalled-activities">
              <Icon Name="alert-triangle" />
              Stalled Activities
            </NavLink>
          </div>
        </AuthorizeView>

        <AuthorizeView Roles="@($"{WombatRoles.SpecialityAdmin},{WombatRoles.SubSpecialityAdmin},{WombatRoles.CommitteeMember}")" Context="programmeAuth">
