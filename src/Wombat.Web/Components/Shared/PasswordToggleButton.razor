@inject IJSRuntime JS

<button type="button" class="password-toggle-btn" @onclick="ToggleAsync">@(_visible ? "Hide" : "Show")</button>

@code {
  private bool _visible;

  [Parameter, EditorRequired] public string For { get; set; } = default!;

  private async Task ToggleAsync()
  {
    _visible = !_visible;
    await JS.InvokeVoidAsync("wombat.togglePasswordVisibility", For, _visible);
  }
}
