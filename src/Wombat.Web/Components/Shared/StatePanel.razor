@if (IsLoading)
{
  <Skeleton Count="SkeletonCount" Height="@SkeletonHeight" />
}
else if (!string.IsNullOrWhiteSpace(LoadError))
{
  <Alert Kind="danger">@LoadError</Alert>
}
else if (IsEmpty)
{
  <div class="detail-card detail-card--empty">
    <div class="state-panel-title">@EmptyTitle</div>
    <div class="state-panel-copy">@EmptyBody</div>
    @if (EmptyActions is not null)
    {
      <div class="form-actions">
        @EmptyActions
      </div>
    }
  </div>
}
else
{
  @ChildContent
}

@code {
  [Parameter] public bool IsLoading { get; set; }
  [Parameter] public string? LoadError { get; set; }
  [Parameter] public bool IsEmpty { get; set; }
  [Parameter] public string EmptyTitle { get; set; } = "Nothing here yet";
  [Parameter] public string EmptyBody { get; set; } = "There is no data to show yet.";
  [Parameter] public RenderFragment? EmptyActions { get; set; }
  [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;
  [Parameter] public int SkeletonCount { get; set; } = 4;
  [Parameter] public string SkeletonHeight { get; set; } = "3rem";
}
