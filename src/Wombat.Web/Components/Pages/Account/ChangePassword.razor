@page "/account/change-password"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<WombatIdentityUser> UserManager
@inject SignInManager<WombatIdentityUser> SignInManager

<PageTitle>Change password</PageTitle>

<PageHeader Title="Change password" Subtitle="Update the password for the current account." />

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
  <Alert Kind="success">@_statusMessage</Alert>
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
  <Alert Kind="danger">@_errorMessage</Alert>
}

<div class="form-container">
  <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="change-password">
    <DataAnnotationsValidator />
    <ValidationSummary class="validation-summary-errors" />

    <div class="form-grid">
      <div class="form-group">
        <label for="current-password">Current password</label>
        <div class="password-wrapper">
          <InputText id="current-password" class="form-control" type="password" @bind-Value="_model.CurrentPassword" />
          <PasswordToggleButton For="current-password" />
        </div>
      </div>

      <div class="form-group">
        <label for="new-password">New password</label>
        <div class="password-wrapper">
          <InputText id="new-password" class="form-control" type="password" @bind-Value="_model.NewPassword" />
          <PasswordToggleButton For="new-password" />
        </div>
      </div>

      <div class="form-group">
        <label for="confirm-password">Confirm password</label>
        <div class="password-wrapper">
          <InputText id="confirm-password" class="form-control" type="password" @bind-Value="_model.ConfirmPassword" />
          <PasswordToggleButton For="confirm-password" />
        </div>
      </div>
    </div>

    <FormActions>
      <a class="btn btn-outline" href="/account/profile">Cancel</a>
      <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Saving..." : "Change password")</button>
    </FormActions>
  </EditForm>
</div>

@code {
  private readonly ChangePasswordModel _model = new();
  private bool _saving;
  private string? _errorMessage;
  private string? _statusMessage;

  private async Task SaveAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      if (!string.Equals(_model.NewPassword, _model.ConfirmPassword, StringComparison.Ordinal))
      {
        _errorMessage = "The password confirmation does not match.";
        return;
      }

      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
        ?? throw new InvalidOperationException("The current user identifier is missing.");

      var user = await UserManager.FindByIdAsync(userId)
        ?? throw new InvalidOperationException("The current user could not be loaded.");

      var result = await UserManager.ChangePasswordAsync(user, _model.CurrentPassword, _model.NewPassword);

      if (!result.Succeeded)
      {
        _errorMessage = string.Join(" ", result.Errors.Select(error => error.Description));
        return;
      }

      await SignInManager.RefreshSignInAsync(user);
      _statusMessage = "Password updated.";
      _model.CurrentPassword = string.Empty;
      _model.NewPassword = string.Empty;
      _model.ConfirmPassword = string.Empty;
    }
    finally
    {
      _saving = false;
    }
  }

  private sealed class ChangePasswordModel
  {
    [Required]
    public string CurrentPassword { get; set; } = string.Empty;

    [Required]
    public string NewPassword { get; set; } = string.Empty;

    [Required]
    public string ConfirmPassword { get; set; } = string.Empty;
  }
}
