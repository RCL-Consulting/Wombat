@page "/account/forgot-password"
@attribute [AllowAnonymous]
@layout Layout.AuthLayout

<PageTitle>Reset password</PageTitle>

<div class="account-form-container shadow">
  <h2>Reset password</h2>
  <Alert Kind="info">
    Password reset is not wired yet in the rewrite. Ask an administrator to issue a new invitation or reset the account directly.
  </Alert>
  <FormActions>
    <a class="btn btn-outline" href="/account/login">Back to sign in</a>
  </FormActions>
</div>
