@page "/account/logout-confirm"

<PageTitle>Sign out</PageTitle>

<PageHeader Title="Sign out" Subtitle="Use the button below to end the current session." />

<div class="form-container">
  <form method="post" action="/account/logout">
    <AntiforgeryToken />
    <FormActions>
      <a class="btn btn-outline" href="/">Cancel</a>
      <button type="submit" class="btn btn-primary">Sign out</button>
    </FormActions>
  </form>
</div>
