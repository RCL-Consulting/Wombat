@page "/"

<PageTitle>Home</PageTitle>

<AuthorizeView Context="homeAuth">
  <Authorized Context="state">
    @{
      var role = ResolvePrimaryRole(state.User);
      var displayName = state.User.Identity?.Name ?? "User";
    }

    <PageHeader Title="@($"Welcome back, {displayName}")" Subtitle="@($"Your current role: {role}")" />

    <div class="dashboard-grid">
      <div class="detail-card">
        <h3>Dashboard</h3>
        <p>Role-specific dashboards land in T011.</p>
      </div>
      <div class="detail-card">
        <h3>Workflow</h3>
        <p>Activity workflow surfaces land in T019 and later tasks.</p>
      </div>
      <div class="detail-card detail-card--empty">
        <div class="state-panel-title">Coming soon</div>
        <div class="state-panel-copy">This stub confirms the authenticated layout, navigation, and design system are working end-to-end.</div>
      </div>
    </div>
  </Authorized>
  <NotAuthorized Context="anonymousHome">
    <RedirectToLogin />
  </NotAuthorized>
</AuthorizeView>

@code {
  private static string ResolvePrimaryRole(System.Security.Claims.ClaimsPrincipal user)
  {
    foreach (var role in WombatRoles.All)
    {
      if (user.IsInRole(role))
      {
        return role;
      }
    }

    return "Authenticated";
  }
}
