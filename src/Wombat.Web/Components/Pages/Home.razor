@page "/"
@using System.Security.Claims

<PageTitle>Home</PageTitle>

<h1>Wombat</h1>

<p>The rewrite foundation is running.</p>

<AuthorizeView>
    <Authorized Context="state">
        <p>Signed in as @state.User.Identity?.Name.</p>

        @if (state.User.IsInRole(WombatRoles.Administrator))
        {
            <p>
                <a href="/admin/invitations">Open invitation administration</a> |
                <a href="/admin/institutions">Open institution administration</a>
            </p>
        }

        <p>
            <a href="/account/logout">Sign out</a>
        </p>
    </Authorized>
    <NotAuthorized>
        <p>
            <a href="/account/login">Sign in</a>
        </p>
    </NotAuthorized>
</AuthorizeView>
