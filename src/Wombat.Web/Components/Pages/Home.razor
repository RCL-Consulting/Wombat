@page "/"
@using Wombat.Web.Navigation
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Dashboard — Wombat</PageTitle>

<AuthorizeView Context="homeAuth">
  <Authorized Context="state">
    @{
      var displayName = state.User.Identity?.Name ?? "User";
      var resolvedRole = ResolvePreferredRole(state.User);
      var otherRoles = GetOtherRoles(state.User, resolvedRole);
    }

    <PageHeader Title="@($"Welcome, {displayName}")" Subtitle="@($"Viewing as {resolvedRole}")" />

    @if (otherRoles.Count > 0)
    {
      <p class="muted" style="margin-top:calc(-1 * var(--space-sm));margin-bottom:var(--space-md)">
        You also act as @string.Join(", ", otherRoles).
        Switch view:
        @foreach (var other in otherRoles)
        {
          <a href="/dashboard/switch/@other" style="margin-left:var(--space-xs)">@other</a>
        }
      </p>
    }

    @switch (resolvedRole)
    {
      case WombatRoles.Administrator:
        <Wombat.Web.Components.Pages.Dashboards.AdministratorDashboard />
        break;
      case WombatRoles.InstitutionalAdmin:
        <Wombat.Web.Components.Pages.Dashboards.InstitutionalAdminDashboard />
        break;
      case WombatRoles.SpecialityAdmin:
        <Wombat.Web.Components.Pages.Dashboards.SpecialityAdminDashboard />
        break;
      case WombatRoles.SubSpecialityAdmin:
        <Wombat.Web.Components.Pages.Dashboards.SubSpecialityAdminDashboard />
        break;
      case WombatRoles.CommitteeMember:
        <Wombat.Web.Components.Pages.Dashboards.CommitteeMemberDashboard />
        break;
      case WombatRoles.Coordinator:
        <Wombat.Web.Components.Pages.Dashboards.CoordinatorDashboard />
        break;
      case WombatRoles.Assessor:
        <Wombat.Web.Components.Pages.Dashboards.AssessorDashboard />
        break;
      case WombatRoles.PendingTrainee:
      case WombatRoles.Trainee:
      default:
        <Wombat.Web.Components.Pages.Dashboards.TraineeDashboard />
        break;
    }
  </Authorized>
  <NotAuthorized Context="anonymousHome">
    <RedirectToLogin />
  </NotAuthorized>
</AuthorizeView>

@code {
  private string ResolvePreferredRole(System.Security.Claims.ClaimsPrincipal user)
  {
    var cookieValue = HttpContextAccessor.HttpContext?.Request.Cookies[DashboardPriority.CookieName];
    if (!string.IsNullOrEmpty(cookieValue) &&
        DashboardPriority.ValidRoles.Contains(cookieValue) &&
        user.IsInRole(cookieValue))
    {
      return cookieValue;
    }

    foreach (var role in DashboardPriority.Order)
    {
      if (user.IsInRole(role))
        return role;
    }

    return WombatRoles.Trainee;
  }

  private static IReadOnlyList<string> GetOtherRoles(System.Security.Claims.ClaimsPrincipal user, string currentRole)
  {
    return DashboardPriority.Order
      .Where(r => !string.Equals(r, currentRole, StringComparison.Ordinal) && user.IsInRole(r))
      .ToList();
  }

}
