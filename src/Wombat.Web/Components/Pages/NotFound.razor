@page "/not-found"
@attribute [AllowAnonymous]

<PageTitle>Page not found</PageTitle>

<PageHeader Title="Page not found" Subtitle="The page you asked for does not exist or has moved." />

<div class="detail-card detail-card--empty">
  <div class="state-panel-title">Nothing to show</div>
