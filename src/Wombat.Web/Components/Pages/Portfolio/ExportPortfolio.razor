@page "/portfolio/export"
@page "/portfolio/export/{TraineeUserId}"
@attribute [Authorize]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<PageTitle>Export Portfolio</PageTitle>

<PageHeader Title="Export portfolio" Subtitle="Generate a PDF export of the trainee's portfolio." />

@if (!string.IsNullOrWhiteSpace(_error))
{
  <Alert Kind="danger">@_error</Alert>
}

@if (_success)
{
  <Alert Kind="success">Portfolio exported successfully. The download should start automatically.</Alert>
}

<div class="form-container">
  <div class="form-grid">
    <FormField Label="From date" InputId="fromDate">
      <input type="date" id="fromDate" class="form-control" @bind="_fromDate" />
    </FormField>
    <FormField Label="To date" InputId="toDate">
      <input type="date" id="toDate" class="form-control" @bind="_toDate" />
    </FormField>
  </div>

  <div class="form-actions">
    <button class="btn btn-primary" @onclick="ExportAsync" disabled="@_exporting">
      @if (_exporting)
      {
        <span>Generating...</span>
      }
      else
      {
        <span>Export PDF</span>
      }
    </button>
  </div>
</div>

@code {
  [Parameter] public string? TraineeUserId { get; set; }

  private DateOnly? _fromDate = DateOnly.FromDateTime(DateTime.Today.AddMonths(-12));
  private DateOnly? _toDate = DateOnly.FromDateTime(DateTime.Today);
  private bool _exporting;
  private bool _success;
  private string? _error;

  protected override async Task OnInitializedAsync()
  {
    if (string.IsNullOrWhiteSpace(TraineeUserId))
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      TraineeUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    }
  }

  private async Task ExportAsync()
  {
    if (string.IsNullOrWhiteSpace(TraineeUserId))
    {
      _error = "No trainee specified.";
      return;
    }

    _exporting = true;
    _error = null;
    _success = false;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      var result = await Sender.Send(new Wombat.Application.Features.Reporting.ExportPortfolioCommand(
        TraineeUserId,
        _fromDate,
        _toDate,
        authState.User));

      await JS.InvokeVoidAsync("wombatFileDownload", result.FileName, result.PdfBytes);
      _success = true;
    }
    catch (UnauthorizedAccessException)
    {
      _error = "You are not authorized to export this portfolio.";
    }
    catch (Exception exception)
    {
      _error = exception.Message;
    }
    finally
    {
      _exporting = false;
    }
  }
}
