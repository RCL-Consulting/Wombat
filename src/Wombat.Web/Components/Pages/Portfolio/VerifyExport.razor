@page "/portfolio/verify"
@attribute [AllowAnonymous]
@inject IScopedSender Sender

<PageTitle>Verify Portfolio Export</PageTitle>

<PageHeader Title="Verify portfolio export" Subtitle="Check whether a PDF was produced by this system." />

<div class="form-container">
  <div class="form-grid">
    <FormField Label="Content hash (SHA-256)" InputId="contentHash" FullWidth="true">
      <input type="text" id="contentHash" class="form-control" @bind="_hash" placeholder="Enter the hash from the PDF footer" />
    </FormField>
  </div>

  <div class="form-actions">
    <button class="btn btn-primary" @onclick="VerifyAsync" disabled="@_loading">
      @(_loading ? "Checking..." : "Verify")
    </button>
  </div>
</div>

@if (_searched)
{
  @if (_result is not null)
  {
    <section class="detail-card" style="margin-top: var(--space-lg);">
      <h3>Export verified</h3>
      <p>This PDF was generated by Wombat on <strong>@_result.ExportedOn.ToString("yyyy-MM-dd HH:mm") UTC</strong>.</p>
      <p>Trainee ID: <strong>@_result.TraineeUserId</strong></p>
      <p>Exported by: <strong>@_result.ExportedByUserId</strong></p>
      @if (_result.FilterFromDate.HasValue || _result.FilterToDate.HasValue)
      {
        <p>Filter: @FormatDateRange(_result.FilterFromDate, _result.FilterToDate)</p>
      }
      <p>File: <strong>@_result.FileName</strong></p>
    </section>
  }
  else
  {
    <div style="margin-top: var(--space-lg);">
      <Alert Kind="warning">No matching export found. This hash does not correspond to any PDF generated by this system.</Alert>
    </div>
  }
}

@code {
  [SupplyParameterFromQuery(Name = "hash")] public string? HashFromQuery { get; set; }

  private string? _hash;
  private bool _loading;
  private bool _searched;
  private Wombat.Application.Features.Reporting.PortfolioExportRecordDto? _result;

  protected override async Task OnInitializedAsync()
  {
    if (!string.IsNullOrWhiteSpace(HashFromQuery))
    {
      _hash = HashFromQuery;
      await VerifyAsync();
    }
  }

  private async Task VerifyAsync()
  {
    if (string.IsNullOrWhiteSpace(_hash))
    {
      return;
    }

    _loading = true;
    _searched = false;

    try
    {
      _result = await Sender.Send(new Wombat.Application.Features.Reporting.VerifyExportQuery(_hash.Trim()));
      _searched = true;
    }
    finally
    {
      _loading = false;
    }
  }

  private static string FormatDateRange(DateOnly? from, DateOnly? to)
  {
    if (from.HasValue && to.HasValue) return $"{from.Value:yyyy-MM-dd} to {to.Value:yyyy-MM-dd}";
    if (from.HasValue) return $"From {from.Value:yyyy-MM-dd}";
    if (to.HasValue) return $"Up to {to.Value:yyyy-MM-dd}";
    return string.Empty;
  }
}
