@page "/committee/reviews/{ReviewId:int}"
@attribute [Authorize(Roles = "CommitteeMember,Coordinator,Administrator,SpecialityAdmin,SubSpecialityAdmin")]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Committee Review</PageTitle>

<PageHeader Title="Committee review" Subtitle="Evidence bundle, decision record, ratification, and appeals in one place." />

@if (!string.IsNullOrWhiteSpace(_status))
{
  <Alert Kind="success">@_status</Alert>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
  <Alert Kind="danger">@_error</Alert>
}

@if (_samplingReport is { AnyWarning: true })
{
  <Alert Kind="warning" Dismissible="true">
    <div>
      <h3>Sampling concentration warnings</h3>
      <p class="muted">
        @_samplingReport.TotalRatedActivities rated observation@(_samplingReport.TotalRatedActivities == 1 ? string.Empty : "s")
        from @_samplingReport.DistinctAssessorCount distinct assessor@(_samplingReport.DistinctAssessorCount == 1 ? string.Empty : "s")
        in the review window. Acknowledge in the decision rationale if these warnings are relevant.
      </p>
      <ul class="list-unstyled">
        @foreach (var epa in _samplingReport.PerEpa)
        {
          <li>
            <strong>@epa.EpaCode — @epa.EpaTitle</strong>
            <span>@epa.RatingCount rating@(epa.RatingCount == 1 ? string.Empty : "s") · @epa.DistinctAssessorCount assessor@(epa.DistinctAssessorCount == 1 ? string.Empty : "s") · @epa.DistinctSourceCount source@(epa.DistinctSourceCount == 1 ? string.Empty : "s")</span>
            <ul class="list-unstyled">
              @if (epa.OneAssessorOverHalf)
              {
                <li>One assessor contributed @epa.DominantAssessorCount of @epa.RatingCount ratings (&gt; 50%).</li>
              }
              @if (epa.SingleSource)
              {
                <li>All ratings came from a single source of evidence.</li>
              }
              @if (epa.FewerThanThreeAssessors)
              {
                <li>Fewer than three distinct assessors across this EPA's evidence.</li>
              }
            </ul>
          </li>
        }
      </ul>
    </div>
  </Alert>
}

@if (_review is not null)
{
  <div class="details-grid">
    <section class="detail-card">
      <h3>Review</h3>
      <dl class="details-list">
        <div><dt>Trainee</dt><dd><code>@_review.TraineeUserId</code></dd></div>
        <div><dt>Panel</dt><dd>@_review.PanelName</dd></div>
        <div><dt>Period</dt><dd>@_review.ReviewPeriodFrom.ToString("yyyy-MM-dd") to @_review.ReviewPeriodTo.ToString("yyyy-MM-dd")</dd></div>
        <div><dt>Mode</dt><dd>@(_review.IsFormative ? "Formative (interim check-in, no binding decision)" : "Summative")</dd></div>
        <div><dt>State</dt><dd>@_review.State</dd></div>
      </dl>
      <FormActions>
        @if (_review.State == CommitteeReviewState.Scheduled)
        {
          <button type="button" class="btn btn-primary" @onclick="StartAsync">Start review</button>
        }
        @if (_review.State == CommitteeReviewState.InProgress && _review.IsFormative)
        {
          <button type="button" class="btn btn-primary" @onclick="CloseFormativeAsync">Close review</button>
        }
        @if (_review.State == CommitteeReviewState.Decided)
        {
          <button type="button" class="btn btn-primary" @onclick="RatifyAsync">Ratify</button>
        }
      </FormActions>
    </section>

    @if (!_review.IsFormative)
    {
      <section class="detail-card">
        <h3>Decision</h3>
        <EditForm Model="_decision" OnValidSubmit="RecordDecisionAsync" FormName="committee-decision">
          <DataAnnotationsValidator />
          <ValidationSummary class="validation-summary-errors" />
          <div class="form-grid">
            <FormField Label="Category" InputId="decision-category" Required="true">
              <InputSelect id="decision-category" class="form-select" @bind-Value="_decision.Category">
                @foreach (var category in Enum.GetValues<CommitteeDecisionCategory>())
                {
                  <option value="@category">@category</option>
                }
              </InputSelect>
            </FormField>
            <FormField Label="Rationale" InputId="decision-rationale" Required="true">
              <InputTextArea id="decision-rationale" class="form-control" @bind-Value="_decision.Rationale" />
            </FormField>
            <FormField Label="Conditions" InputId="decision-conditions">
              <InputTextArea id="decision-conditions" class="form-control" @bind-Value="_decision.Conditions" />
            </FormField>
          </div>
          <FormActions>
            @if (_review.State == CommitteeReviewState.InProgress)
            {
              <button type="submit" class="btn btn-primary">Record decision</button>
            }
          </FormActions>
        </EditForm>

        @if (_review.Decisions.Count > 0)
        {
          <div class="stack-list">
            @foreach (var decision in _review.Decisions)
            {
              <article class="detail-card detail-card--compact">
                <h4>@decision.Category</h4>
                <p>@decision.Rationale</p>
                @if (!string.IsNullOrWhiteSpace(decision.Conditions))
                {
                  <p><strong>Conditions:</strong> @decision.Conditions</p>
                }
              </article>
            }
          </div>
        }
      </section>

      <section class="detail-card">
        <h3>Pending entrustment decisions</h3>
        <p class="muted">
          Decisions staged here are issued atomically when the committee review is ratified.
          They become formal Statements of Awarded Responsibility (STAR) at that point.
        </p>

        @if (_review.State is CommitteeReviewState.InProgress or CommitteeReviewState.Decided)
        {
          <EditForm Model="_pending" OnValidSubmit="StagePendingAsync" FormName="pending-entrustment">
            <DataAnnotationsValidator />
            <ValidationSummary class="validation-summary-errors" />
            <div class="form-grid">
              <FormField Label="EPA" InputId="pending-epa" Required="true">
                <InputSelect id="pending-epa" class="form-select" @bind-Value="_pending.EpaId">
                  <option value="0">Select an EPA…</option>
                  @foreach (var epa in _epas)
                  {
                    <option value="@epa.Id">@epa.Code — @epa.Title</option>
                  }
                </InputSelect>
              </FormField>
              <FormField Label="Authorised level" InputId="pending-level" Required="true">
                <InputSelect id="pending-level" class="form-select" @bind-Value="_pending.AuthorisedLevelId">
                  <option value="0">Select a level…</option>
                  @foreach (var scale in _scales)
                  {
                    <optgroup label="@scale.Name">
                      @foreach (var level in scale.Levels)
                      {
                        <option value="@level.Id">@level.Order. @level.Label</option>
                      }
                    </optgroup>
                  }
                </InputSelect>
              </FormField>
              <FormField Label="Issued on" InputId="pending-issued" Required="true">
                <InputDate id="pending-issued" class="form-control" @bind-Value="_pending.IssuedOn" />
              </FormField>
              <FormField Label="Expires on" InputId="pending-expires">
                <InputDate id="pending-expires" class="form-control" @bind-Value="_pending.ExpiresOn" />
              </FormField>
              <FormField Label="Rationale" InputId="pending-rationale" Required="true">
                <InputTextArea id="pending-rationale" class="form-control" @bind-Value="_pending.Rationale" />
              </FormField>
            </div>
            <FormActions>
              <button type="submit" class="btn btn-primary">Stage pending decision</button>
            </FormActions>
          </EditForm>
        }

        @if (_pendingDecisions.Count == 0)
        {
          <p>No pending entrustment decisions have been staged for this review.</p>
        }
        else
        {
          <ul class="list-unstyled">
            @foreach (var pending in _pendingDecisions)
            {
              <li>
                <strong>@pending.EpaCode — @pending.EpaTitle</strong>
                <span>@pending.AuthorisedLevelLabel · issued @pending.IssuedOn.ToString("yyyy-MM-dd")@(pending.ExpiresOn.HasValue ? $" · expires {pending.ExpiresOn:yyyy-MM-dd}" : string.Empty)</span>
                <p>@pending.Rationale</p>
                @if (_review.State is CommitteeReviewState.InProgress or CommitteeReviewState.Decided)
                {
                  <button type="button" class="btn btn-link" @onclick="() => RemovePendingAsync(pending.Id)">Remove</button>
                }
              </li>
            }
          </ul>
        }
      </section>
    }

    <section class="detail-card">
      <h3>Evidence snapshot</h3>
      @if (_review.EvidenceItems.Count == 0)
      {
        <p>No evidence has been frozen yet. Starting the review captures the current bundle.</p>
      }
      else
      {
        <ul class="list-unstyled">
          @foreach (var item in _review.EvidenceItems)
          {
            <li><strong>@item.SourceLabel</strong> <span>@item.Summary</span></li>
          }
        </ul>
      }
    </section>

    <section class="detail-card">
      <h3>Rating trajectory by EPA</h3>
      @if (_trajectories.Count == 0)
      {
        <p class="muted">No rated observations on file for this trainee.</p>
      }
      else
      {
        <div class="stack-list">
          @foreach (var trajectory in _trajectories)
          {
            <article class="detail-card detail-card--compact">
              <h4>@trajectory.EpaCode — @trajectory.EpaTitle</h4>
              <p class="muted">@trajectory.Points.Count observation@(trajectory.Points.Count == 1 ? string.Empty : "s")</p>
              <TrajectoryChart Points="@BuildChartPoints(trajectory)"
                               AriaLabel="@($"Rating trajectory for {trajectory.EpaCode}")" />
            </article>
          }
        </div>
      }
    </section>

    @if (!_review.IsFormative)
    {
      <section class="detail-card">
        <h3>Appeals</h3>
        <EditForm Model="_appeal" OnValidSubmit="ResolveAppealAsync" FormName="committee-appeal-resolution">
          <DataAnnotationsValidator />
          <ValidationSummary class="validation-summary-errors" />
          <div class="form-grid">
            <FormField Label="Outcome" InputId="appeal-outcome" Required="true">
              <InputSelect id="appeal-outcome" class="form-select" @bind-Value="_appeal.Outcome">
                @foreach (var outcome in Enum.GetValues<CommitteeAppealOutcome>())
                {
                  <option value="@outcome">@outcome</option>
                }
              </InputSelect>
            </FormField>
            @if (_appeal.Outcome == CommitteeAppealOutcome.Remitted)
            {
              <FormField Label="Replacement category" InputId="appeal-category" Required="true">
                <InputSelect id="appeal-category" class="form-select" @bind-Value="_appeal.RemittedCategory">
                  @foreach (var category in Enum.GetValues<CommitteeDecisionCategory>())
                  {
                    <option value="@category">@category</option>
                  }
                </InputSelect>
              </FormField>
              <FormField Label="Replacement rationale" InputId="appeal-rationale" Required="true">
                <InputTextArea id="appeal-rationale" class="form-control" @bind-Value="_appeal.RemittedRationale" />
              </FormField>
            }
          </div>
          <FormActions>
            @if (_review.State == CommitteeReviewState.UnderAppeal)
            {
              <button type="submit" class="btn btn-primary">Resolve appeal</button>
            }
          </FormActions>
        </EditForm>

        @if (_review.Appeals.Count > 0)
        {
          <ul class="list-unstyled">
            @foreach (var appeal in _review.Appeals)
            {
              <li><strong>@appeal.LodgedOn.ToString("yyyy-MM-dd")</strong> @appeal.Reason (@(appeal.Outcome?.ToString() ?? "Open"))</li>
            }
          </ul>
        }
      </section>
    }
  </div>
}

@code {
  [Parameter] public int ReviewId { get; set; }

  private CommitteeReviewDetailDto? _review;
  private string? _status;
  private string? _error;
  private DecisionFormModel _decision = new();
  private AppealResolutionModel _appeal = new();
  private PendingDecisionFormModel _pending = new();
  private IReadOnlyList<PendingEntrustmentDecisionDto> _pendingDecisions = Array.Empty<PendingEntrustmentDecisionDto>();
  private IReadOnlyList<EpaDto> _epas = Array.Empty<EpaDto>();
  private IReadOnlyList<EntrustmentScaleDto> _scales = Array.Empty<EntrustmentScaleDto>();
  private SamplingConcentrationReportDto? _samplingReport;
  private IReadOnlyList<EpaTrajectoryDto> _trajectories = Array.Empty<EpaTrajectoryDto>();

  protected override async Task OnParametersSetAsync()
  {
    await LoadAsync();
  }

  private async Task LoadAsync()
  {
    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _review = await Sender.Send(new GetCommitteeReviewByIdQuery(ReviewId, authState.User));
      _pendingDecisions = await Sender.Send(new ListPendingEntrustmentDecisionsForReviewQuery(ReviewId));
      _samplingReport = await Sender.Send(new GetSamplingConcentrationWarningsQuery(ReviewId));
      _trajectories = await Sender.Send(new GetEpaTrajectoryForTraineeQuery(_review.TraineeUserId));
      if (_epas.Count == 0)
      {
        _epas = await Sender.Send(new ListEpasForSubSpecialityQuery(authState.User));
      }
      if (_scales.Count == 0)
      {
        _scales = await Sender.Send(new GetEntrustmentScalesListQuery());
      }
    }
    catch (Exception exception)
    {
      _error = exception.Message;
    }
  }

  private async Task StartAsync()
  {
    await ExecuteAsync(user => Sender.Send(new StartCommitteeReviewCommand(ReviewId, user)), "Review started.");
  }

  private async Task RecordDecisionAsync()
  {
    await ExecuteAsync(
      user => Sender.Send(new RecordCommitteeDecisionCommand(ReviewId, _decision.Category, _decision.Rationale, _decision.Conditions, user)),
      "Decision recorded.");
  }

  private async Task RatifyAsync()
  {
    await ExecuteAsync(user => Sender.Send(new RatifyCommitteeDecisionCommand(ReviewId, user)), "Decision ratified.");
  }

  private async Task CloseFormativeAsync()
  {
    await ExecuteAsync(user => Sender.Send(new CloseFormativeReviewCommand(ReviewId, user)), "Formative review closed.");
  }

  private async Task ResolveAppealAsync()
  {
    await ExecuteAsync(
      user => Sender.Send(new ResolveAppealCommand(
        ReviewId,
        _appeal.Outcome,
        _appeal.RemittedCategory,
        _appeal.RemittedRationale,
        _appeal.RemittedConditions,
        user)),
      "Appeal resolved.");
  }

  private async Task StagePendingAsync()
  {
    _error = null;
    _status = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      await Sender.Send(new StagePendingEntrustmentDecisionCommand(
        ReviewId,
        null,
        _pending.EpaId,
        _pending.AuthorisedLevelId,
        _pending.IssuedOn,
        _pending.ExpiresOn,
        _pending.Rationale,
        Array.Empty<EntrustmentEvidenceLinkInput>(),
        authState.User));
      _pending = new PendingDecisionFormModel();
      _pendingDecisions = await Sender.Send(new ListPendingEntrustmentDecisionsForReviewQuery(ReviewId));
      _status = "Pending entrustment decision staged.";
    }
    catch (Exception exception)
    {
      _error = exception.Message;
    }
  }

  private async Task RemovePendingAsync(int pendingId)
  {
    _error = null;
    _status = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      await Sender.Send(new RemovePendingEntrustmentDecisionCommand(ReviewId, pendingId, authState.User));
      _pendingDecisions = await Sender.Send(new ListPendingEntrustmentDecisionsForReviewQuery(ReviewId));
      _status = "Pending entrustment decision removed.";
    }
    catch (Exception exception)
    {
      _error = exception.Message;
    }
  }

  private static IReadOnlyList<TrajectoryChart.ChartPoint> BuildChartPoints(EpaTrajectoryDto trajectory)
    => trajectory.Points
      .Select((point, index) => new TrajectoryChart.ChartPoint(point.ObservedOn, point.Rating, index, point.Source))
      .ToArray();

  private async Task ExecuteAsync(Func<System.Security.Claims.ClaimsPrincipal, Task<CommitteeReviewDetailDto>> action, string status)
  {
    _error = null;
    _status = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _review = await action(authState.User);
      _status = status;
    }
    catch (Exception exception)
    {
      _error = exception.Message;
    }
  }

  private sealed class DecisionFormModel
  {
    [Required]
    public CommitteeDecisionCategory Category { get; set; } = CommitteeDecisionCategory.SatisfactoryProgress;

    [Required]
    public string Rationale { get; set; } = string.Empty;

    public string? Conditions { get; set; }
  }

  private sealed class AppealResolutionModel
  {
    [Required]
    public CommitteeAppealOutcome Outcome { get; set; } = CommitteeAppealOutcome.Dismissed;

    public CommitteeDecisionCategory? RemittedCategory { get; set; }
    public string? RemittedRationale { get; set; }
    public string? RemittedConditions { get; set; }
  }

  private sealed class PendingDecisionFormModel
  {
    [Range(1, int.MaxValue, ErrorMessage = "Select an EPA.")]
    public int EpaId { get; set; }

    [Range(1, int.MaxValue, ErrorMessage = "Select an entrustment level.")]
    public int AuthorisedLevelId { get; set; }

    [Required]
    public DateOnly IssuedOn { get; set; } = DateOnly.FromDateTime(DateTime.UtcNow);

    public DateOnly? ExpiresOn { get; set; }

    [Required]
    public string Rationale { get; set; } = string.Empty;
  }
}
