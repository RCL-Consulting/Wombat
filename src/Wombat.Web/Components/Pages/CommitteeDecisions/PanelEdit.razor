@page "/committee/panels/new"
@page "/committee/panels/{PanelId:int}"
@attribute [Authorize(Roles = "Administrator,InstitutionalAdmin,SpecialityAdmin,SubSpecialityAdmin")]
@inject IScopedSender Sender
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Decision Panel</PageTitle>

<PageHeader Title="Decision panel" Subtitle="Panels hold the named members who can review, ratify, and resolve appeals.">
  <Actions>
    <a class="btn btn-outline btn-sm" href="/committee/panels">Back to panels</a>
  </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(_status))
{
  <Alert Kind="success">@_status</Alert>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
  <Alert Kind="danger">@_error</Alert>
}

<StatePanel IsLoading="_loading" IsEmpty="false" EmptyTitle="" EmptyBody="" LoadError="@_loadError">
  <div class="details-grid">
    <section class="detail-card">
      <h3>@(PanelId.HasValue ? "Update members" : "Create panel")</h3>
      <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="committee-panel">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary-errors" />
        <div class="form-grid">
          @if (!PanelId.HasValue)
          {
            <FormField Label="Panel name" InputId="panel-name" Required="true">
              <InputText id="panel-name" class="form-control" @bind-Value="_model.Name" />
            </FormField>
            <FormField Label="Scope" InputId="panel-scope" Required="true">
              <InputSelect id="panel-scope" class="form-select" @bind-Value="_model.Scope">
                @foreach (var scope in Enum.GetValues<DecisionPanelScope>())
                {
                  <option value="@scope">@scope</option>
                }
              </InputSelect>
            </FormField>

            @if (_model.Scope == DecisionPanelScope.Institution)
            {
              <FormField Label="Institution" InputId="panel-institution" Required="true">
                <InputSelect id="panel-institution" class="form-select" @bind-Value="_model.InstitutionId">
                  <option value="">Select institution</option>
                  @foreach (var institution in _institutions)
                  {
                    <option value="@institution.Id">@institution.Name</option>
                  }
                </InputSelect>
              </FormField>
            }
            else if (_model.Scope == DecisionPanelScope.Speciality)
            {
              <FormField Label="Speciality" InputId="panel-speciality" Required="true">
                <InputSelect id="panel-speciality" class="form-select" @bind-Value="_model.SpecialityId">
                  <option value="">Select speciality</option>
                  @foreach (var speciality in _specialities)
                  {
                    var institutionName = _institutions.FirstOrDefault(institution => institution.Id == speciality.InstitutionId)?.Name ?? "Unknown";
                    <option value="@speciality.Id">@institutionName / @speciality.Name</option>
                  }
                </InputSelect>
              </FormField>
            }
          }

          <FormField Label="Chair" InputId="panel-chair" Required="true">
            <InputSelect id="panel-chair" class="form-select" @bind-Value="_model.ChairUserId">
              <option value="">Select chair</option>
              @foreach (var candidate in _candidates)
              {
                <option value="@candidate.UserId">@FormatCandidate(candidate)</option>
              }
            </InputSelect>
          </FormField>

          <FormField Label="Members" InputId="panel-members" FullWidth="true">
            <select id="panel-members" class="form-select" multiple size="6" @onchange="OnMembersChanged">
              @foreach (var candidate in _candidates.Where(candidate => candidate.UserId != _model.ChairUserId))
              {
                var isSelected = _model.MemberUserIds.Contains(candidate.UserId);
                <option value="@candidate.UserId" selected="@isSelected">@FormatCandidate(candidate)</option>
              }
            </select>
            <small class="muted">Hold Ctrl (Windows) / Cmd (Mac) to select multiple. The chair is excluded automatically.</small>
          </FormField>

          <FormField Label="External members" InputId="panel-external" FullWidth="true">
            <select id="panel-external" class="form-select" multiple size="6" @onchange="OnExternalsChanged">
              @foreach (var candidate in _candidates.Where(candidate => candidate.UserId != _model.ChairUserId && !_model.MemberUserIds.Contains(candidate.UserId)))
              {
                var isSelected = _model.ExternalUserIds.Contains(candidate.UserId);
                <option value="@candidate.UserId" selected="@isSelected">@FormatCandidate(candidate)</option>
              }
            </select>
            <small class="muted">External examiners selected from the CommitteeMember pool. Cross-institution externals are not yet supported.</small>
          </FormField>
        </div>
        <FormActions>
          <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Saving..." : "Save panel")</button>
        </FormActions>
      </EditForm>
    </section>
  </div>
</StatePanel>

@code {
  [Parameter] public int? PanelId { get; set; }

  private string? _status;
  private string? _error;
  private string? _loadError;
  private bool _loading = true;
  private bool _saving;
  private PanelFormModel _model = new();
  private IReadOnlyList<InstitutionDto> _institutions = [];
  private IReadOnlyList<SpecialityDto> _specialities = [];
  private IReadOnlyList<PanelMemberCandidateDto> _candidates = [];

  protected override async Task OnParametersSetAsync()
  {
    await LoadAsync();
  }

  private async Task LoadAsync()
  {
    _loading = true;
    _loadError = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _institutions = await Sender.Send(new GetInstitutionsListQuery(authState.User));
      _specialities = await Sender.Send(new GetSpecialitiesListQuery(authState.User));
      _candidates = await Sender.Send(new ListPanelMemberCandidatesQuery(authState.User));

      if (PanelId.HasValue)
      {
        var panel = await Sender.Send(new GetDecisionPanelByIdQuery(PanelId.Value, authState.User));
        if (panel is null)
        {
          _loadError = "The decision panel could not be found.";
          return;
        }
        _model = new PanelFormModel
        {
          Name = panel.Name,
          Scope = panel.Scope,
          InstitutionId = panel.InstitutionId,
          SpecialityId = panel.SpecialityId,
          ChairUserId = panel.Members.FirstOrDefault(member => member.Role == DecisionPanelMemberRole.Chair)?.UserId ?? string.Empty,
          MemberUserIds = panel.Members.Where(member => member.Role == DecisionPanelMemberRole.Member).Select(member => member.UserId).ToHashSet(StringComparer.Ordinal),
          ExternalUserIds = panel.Members.Where(member => member.Role == DecisionPanelMemberRole.External).Select(member => member.UserId).ToHashSet(StringComparer.Ordinal)
        };
      }
    }
    catch (Exception exception)
    {
      _loadError = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private static string FormatCandidate(PanelMemberCandidateDto candidate)
    => $"{candidate.FirstName} {candidate.LastName} ({candidate.Email})";

  private void OnMembersChanged(ChangeEventArgs e)
  {
    _model.MemberUserIds = ToHashSet(e.Value);
    // Externals must not overlap members.
    _model.ExternalUserIds.ExceptWith(_model.MemberUserIds);
  }

  private void OnExternalsChanged(ChangeEventArgs e)
  {
    _model.ExternalUserIds = ToHashSet(e.Value);
  }

  private static HashSet<string> ToHashSet(object? value)
  {
    if (value is string[] array)
    {
      return new HashSet<string>(array, StringComparer.Ordinal);
    }
    if (value is IEnumerable<object> objects)
    {
      return new HashSet<string>(objects.Select(item => item?.ToString() ?? string.Empty).Where(item => !string.IsNullOrEmpty(item)), StringComparer.Ordinal);
    }
    return new HashSet<string>(StringComparer.Ordinal);
  }

  private async Task SaveAsync()
  {
    _saving = true;
    _error = null;
    _status = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      var members = BuildMembers();

      if (PanelId.HasValue)
      {
        await Sender.Send(new UpdateDecisionPanelCommand(PanelId.Value, members, authState.User));
        _status = "Panel members updated.";
      }
      else
      {
        var result = await Sender.Send(new CreateDecisionPanelCommand(
          _model.Name,
          _model.Scope,
          _model.InstitutionId,
          _model.SpecialityId,
          members,
          authState.User));

        NavigationManager.NavigateTo($"/committee/panels/{result.Id}", forceLoad: true);
      }
    }
    catch (Exception exception)
    {
      _error = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private IReadOnlyList<DecisionPanelMemberInput> BuildMembers()
  {
    var members = new List<DecisionPanelMemberInput>();

    if (!string.IsNullOrWhiteSpace(_model.ChairUserId))
    {
      members.Add(new DecisionPanelMemberInput(_model.ChairUserId.Trim(), DecisionPanelMemberRole.Chair));
    }

    members.AddRange(_model.MemberUserIds.Select(userId => new DecisionPanelMemberInput(userId, DecisionPanelMemberRole.Member)));
    members.AddRange(_model.ExternalUserIds.Select(userId => new DecisionPanelMemberInput(userId, DecisionPanelMemberRole.External)));
    return members;
  }

  private sealed class PanelFormModel
  {
    [Required]
    [MaxLength(200)]
    public string Name { get; set; } = string.Empty;

    [Required]
    public DecisionPanelScope Scope { get; set; } = DecisionPanelScope.Speciality;

    public int? InstitutionId { get; set; }
    public int? SpecialityId { get; set; }

    [Required]
    public string ChairUserId { get; set; } = string.Empty;

    public HashSet<string> MemberUserIds { get; set; } = new(StringComparer.Ordinal);
    public HashSet<string> ExternalUserIds { get; set; } = new(StringComparer.Ordinal);
  }
}
