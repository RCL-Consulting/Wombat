@page "/admin/trainees"
@attribute [Authorize(Policy = "Administrator")]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Trainees</PageTitle>

<PageHeader Title="Trainees" Subtitle="Admit pending trainees into a curriculum and maintain active trainee profiles." />

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
  <Alert Kind="danger">@_errorMessage</Alert>
}

<StatePanel IsLoading="_loading" IsEmpty="false" EmptyTitle="" EmptyBody="">
  <div class="details-grid">
    <section class="detail-card">
      <h3>Pending admission</h3>
      @if (_pendingTrainees.Count == 0)
      {
        <div class="detail-card detail-card--empty-compact">No pending trainees found.</div>
      }
      else
      {
        <DataTable TItem="PendingTraineeDto" Items="_pendingTrainees" Caption="Pending trainees">
          <HeaderRow>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Institution</th>
              <th></th>
            </tr>
          </HeaderRow>
          <Row Context="trainee">
            <tr>
              <td>@($"{trainee.FirstName} {trainee.LastName}")</td>
              <td>@trainee.Email</td>
              <td>@GetInstitutionName(trainee.InstitutionId)</td>
              <td><a class="btn btn-primary btn-sm" href="@($"/admin/trainees/edit?userId={Uri.EscapeDataString(trainee.UserId)}")">Admit to curriculum</a></td>
            </tr>
          </Row>
        </DataTable>
      }
    </section>

    <section class="detail-card">
      <h3>Active profiles</h3>
      @if (_trainees.Count == 0)
      {
        <div class="detail-card detail-card--empty-compact">No trainee profiles found.</div>
      }
      else
      {
        <DataTable TItem="TraineeProfileDto" Items="_trainees" Caption="Active trainee profiles">
          <HeaderRow>
            <tr>
              <th>Name</th>
              <th>Curriculum</th>
              <th>Sub-speciality</th>
              <th>Expected completion</th>
              <th>Status</th>
              <th></th>
            </tr>
          </HeaderRow>
          <Row Context="trainee">
            <tr>
              <td>@($"{trainee.FirstName} {trainee.LastName}")</td>
              <td>@($"{trainee.CurriculumName} ({trainee.CurriculumVersion})")</td>
              <td>@trainee.SubSpecialityName</td>
              <td>@trainee.ExpectedCompletionDate.ToString("yyyy-MM-dd")</td>
              <td>@(trainee.IsActive ? "Active" : "Inactive")</td>
              <td><a class="btn btn-outline btn-sm" href="@($"/admin/trainees/edit?id={trainee.Id}")">Edit</a></td>
            </tr>
          </Row>
        </DataTable>
      }
    </section>
  </div>
</StatePanel>

@code {
  private IReadOnlyList<PendingTraineeDto> _pendingTrainees = [];
  private IReadOnlyList<TraineeProfileDto> _trainees = [];
  private IReadOnlyList<InstitutionDto> _institutions = [];
  private bool _loading = true;
  private string? _errorMessage;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _institutions = await Sender.Send(new GetInstitutionsListQuery(authState.User));
      _pendingTrainees = await Sender.Send(new ListPendingTraineesQuery());
      _trainees = await Sender.Send(new ListTraineesForSpecialityQuery());
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private string GetInstitutionName(int? institutionId)
    => _institutions.FirstOrDefault(entity => entity.Id == institutionId)?.Name ?? "Unscoped";
}
