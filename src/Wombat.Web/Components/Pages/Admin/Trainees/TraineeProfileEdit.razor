@page "/admin/trainees/edit"
@attribute [Authorize(Policy = "Administrator")]
@inject IScopedSender Sender
@inject NavigationManager NavigationManager

<PageTitle>Trainee Profile</PageTitle>

<h1>Trainee Profile</h1>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <p>@_errorMessage</p>
}

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <p>@_statusMessage</p>
}

@if (_loading)
{
    <p>Loading trainee profile...</p>
}
else if (_model is not null)
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="trainee-profile">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Email</label>
            <InputText class="form-control" @bind-Value="_model.Email" disabled />
        </div>

        <div class="mb-3">
            <label>Name</label>
            <InputText class="form-control" @bind-Value="_model.FullName" disabled />
        </div>

        <div class="mb-3">
            <label for="curriculum-id">Curriculum</label>
            <InputSelect id="curriculum-id" class="form-select" @bind-Value="_model.CurriculumId">
                @foreach (var curriculum in _curricula)
                {
                    <option value="@curriculum.Id">@($"{curriculum.Name} ({curriculum.Version})")</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label for="programme-start-date">Programme start date</label>
            <InputDate id="programme-start-date" class="form-control" @bind-Value="_model.ProgrammeStartDate" />
        </div>

        <div class="mb-3">
            <label for="expected-completion-date">Expected completion date</label>
            <InputDate id="expected-completion-date" class="form-control" @bind-Value="_model.ExpectedCompletionDate" />
            <small>Leave this empty to derive it from the curriculum window.</small>
        </div>

        <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Saving..." : (_isAdmission ? "Admit trainee" : "Save profile"))</button>

        @if (!_isAdmission && _model.IsActive)
        {
            <button type="button" class="btn btn-outline-danger ms-2" disabled="@_saving" @onclick="DeactivateAsync">Deactivate</button>
        }
    </EditForm>
}

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int? Id { get; set; }

    [SupplyParameterFromQuery(Name = "userId")]
    public string? UserId { get; set; }

    private IReadOnlyList<CurriculumDto> _curricula = [];
    private TraineeProfileFormModel? _model;
    private bool _loading = true;
    private bool _saving;
    private bool _isAdmission;
    private string? _errorMessage;
    private string? _statusMessage;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _errorMessage = null;
        _statusMessage = null;

        try
        {
            _curricula = await Sender.Send(new GetCurriculaListQuery());

            if (Id.HasValue)
            {
                var profile = await Sender.Send(new GetTraineeProfileByIdQuery(Id.Value));
                _isAdmission = false;
                _model = new TraineeProfileFormModel
                {
                    Id = profile.Id,
                    UserId = profile.UserId,
                    Email = profile.Email,
                    FullName = $"{profile.FirstName} {profile.LastName}",
                    CurriculumId = profile.CurriculumId,
                    ProgrammeStartDate = profile.ProgrammeStartDate,
                    ExpectedCompletionDate = profile.ExpectedCompletionDate,
                    IsActive = profile.IsActive
                };
            }
            else if (!string.IsNullOrWhiteSpace(UserId))
            {
                _isAdmission = true;
                var pendingUsers = await Sender.Send(new ListPendingTraineesQuery());
                var pendingUser = pendingUsers.FirstOrDefault(entity => entity.UserId == UserId)
                    ?? throw new InvalidOperationException("The pending trainee could not be found.");

                var defaultCurriculum = ResolveDefaultCurriculum(pendingUser);

                _model = new TraineeProfileFormModel
                {
                    UserId = pendingUser.UserId,
                    Email = pendingUser.Email,
                    FullName = $"{pendingUser.FirstName} {pendingUser.LastName}",
                    CurriculumId = defaultCurriculum?.Id ?? _curricula.FirstOrDefault()?.Id ?? 0,
                    ProgrammeStartDate = DateOnly.FromDateTime(DateTime.Today)
                };
            }
            else
            {
                throw new InvalidOperationException("A trainee profile id or user id is required.");
            }
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private CurriculumDto? ResolveDefaultCurriculum(PendingTraineeDto pendingUser)
    {
        if (pendingUser.SubSpecialityIds.Count > 0)
        {
            return _curricula.FirstOrDefault(entity => pendingUser.SubSpecialityIds.Contains(entity.SubSpecialityId));
        }

        if (pendingUser.SpecialityIds.Count > 0)
        {
            return _curricula.FirstOrDefault(entity => pendingUser.SpecialityIds.Contains(entity.SpecialityId));
        }

        return _curricula.FirstOrDefault();
    }

    private async Task SaveAsync()
    {
        if (_model is null)
        {
            return;
        }

        _saving = true;
        _errorMessage = null;
        _statusMessage = null;

        try
        {
            if (_isAdmission)
            {
                var result = await Sender.Send(new AdmitTraineeCommand(
                    _model.UserId,
                    _model.CurriculumId,
                    _model.ProgrammeStartDate,
                    _model.ExpectedCompletionDate));

                NavigationManager.NavigateTo($"/admin/trainees/edit?id={result.Id}", forceLoad: false);
                return;
            }

            await Sender.Send(new UpdateTraineeProfileCommand(
                _model.Id,
                _model.CurriculumId,
                _model.ProgrammeStartDate,
                _model.ExpectedCompletionDate));

            _statusMessage = "Trainee profile saved.";
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeactivateAsync()
    {
        if (_model is null || _model.Id <= 0)
        {
            return;
        }

        _saving = true;
        _errorMessage = null;
        _statusMessage = null;

        try
        {
            await Sender.Send(new DeactivateTraineeProfileCommand(_model.Id));
            _model.IsActive = false;
            _statusMessage = "Trainee profile deactivated.";
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class TraineeProfileFormModel
    {
        public int Id { get; set; }
        public string UserId { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;

        [Required]
        [Range(1, int.MaxValue)]
        public int CurriculumId { get; set; }

        [Required]
        public DateOnly ProgrammeStartDate { get; set; }

        public DateOnly? ExpectedCompletionDate { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
