@page "/admin/activity-types"
@attribute [Authorize(Policy = "AdministratorOrInstitutionalAdmin")]
@using Wombat.Domain.Activities
@using Wombat.Application.Features.Institutions
@using Wombat.Application.Features.Institutions.Queries.GetInstitutionsList
@using Wombat.Application.Features.Institutions.Queries.GetSpecialitiesList
@using Wombat.Application.Features.Institutions.Queries.GetSubSpecialitiesList
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Activity Types</PageTitle>

<PageHeader Title="Activity types" Subtitle="Manage draft and published activity-type definitions.">
  <Actions>
    <a class="btn btn-primary" href="/admin/activity-types/new">New activity type</a>
  </Actions>
</PageHeader>

<div class="search-container shadow mb-3">
  <div class="search-grid">
    <div class="search-field">
      <label for="activity-type-filter">Search</label>
      <input id="activity-type-filter" class="search-input" @bind="_search" @bind:event="oninput" />
    </div>
  </div>
</div>

<StatePanel IsLoading="_loading" LoadError="@_error" IsEmpty="@(!_loading && FilteredItems.Count == 0)" EmptyTitle="No activity types" EmptyBody="Create the first activity type to start the builder.">
  <DataTable Items="FilteredItems" Caption="Configured activity types">
    <HeaderRow>
      <tr>
        <th>Name</th>
        <th>Key</th>
        <th>Scope</th>
        <th>Published</th>
        <th>Draft</th>
        <th>Status</th>
        <th></th>
      </tr>
    </HeaderRow>
    <Row Context="item">
      <tr>
        <td>@item.Name</td>
        <td><code>@item.Key</code></td>
        <td>@FormatScope(item)</td>
        <td>v@(item.PublishedVersion)</td>
        <td>@(item.HasDraft ? "Draft saved" : "None")</td>
        <td>@(item.IsActive ? "Active" : "Inactive")</td>
        <td class="actions-cell">
          <a class="btn btn-outline btn-sm" href="@($"/admin/activity-types/{item.Id}")">Edit</a>
        </td>
      </tr>
    </Row>
    <Empty>
      <div class="detail-card detail-card--empty">
        No activity types match the current filter.
      </div>
    </Empty>
  </DataTable>
</StatePanel>

@code {
  private readonly List<ActivityTypeAdminListItemDto> _items = [];
  private IReadOnlyList<InstitutionDto> _institutions = [];
  private IReadOnlyList<SpecialityDto> _specialities = [];
  private IReadOnlyList<SubSpecialityDto> _subSpecialities = [];
  private bool _loading = true;
  private string? _error;
  private string? _search;

  private IReadOnlyList<ActivityTypeAdminListItemDto> FilteredItems =>
    _items
      .Where(item =>
        string.IsNullOrWhiteSpace(_search) ||
        item.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        item.Key.Contains(_search, StringComparison.OrdinalIgnoreCase))
      .ToList();

  protected override async Task OnInitializedAsync()
  {
    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _items.AddRange(await Sender.Send(new Wombat.Application.Features.Activities.Queries.ListActivityTypesAdmin.ListActivityTypesAdminQuery(authState.User)));
      _institutions = await Sender.Send(new GetInstitutionsListQuery(authState.User));
      _specialities = await Sender.Send(new GetSpecialitiesListQuery(authState.User));
      _subSpecialities = await Sender.Send(new GetSubSpecialitiesListQuery(authState.User));
    }
    catch (Exception exception)
    {
      _error = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private string FormatScope(ActivityTypeAdminListItemDto item) => item.Scope switch
  {
    ActivityScope.Global => "Global",
    ActivityScope.Institution => InstitutionLabel(item.ScopeId),
    ActivityScope.Speciality => SpecialityLabel(item.ScopeId),
    ActivityScope.SubSpeciality => SubSpecialityLabel(item.ScopeId),
    _ => item.Scope.ToString()
  };

  private string InstitutionLabel(int? institutionId)
  {
    if (!institutionId.HasValue) return "Institution";
    var institution = _institutions.FirstOrDefault(i => i.Id == institutionId.Value);
    return institution is null ? $"Institution · #{institutionId}" : $"Institution · {institution.Name}";
  }

  private string SpecialityLabel(int? specialityId)
  {
    if (!specialityId.HasValue) return "Speciality";
    var speciality = _specialities.FirstOrDefault(s => s.Id == specialityId.Value);
    if (speciality is null) return $"Speciality · #{specialityId}";
    // Specialities are national now (T091); College prefix lands with the Phase 5 admin rework.
    return $"Speciality · {speciality.Name}";
  }

  private string SubSpecialityLabel(int? subSpecialityId)
  {
    if (!subSpecialityId.HasValue) return "Sub-speciality";
    var subSpeciality = _subSpecialities.FirstOrDefault(s => s.Id == subSpecialityId.Value);
    if (subSpeciality is null) return $"Sub-speciality · #{subSpecialityId}";
    var speciality = _specialities.FirstOrDefault(s => s.Id == subSpeciality.SpecialityId);
    if (speciality is null) return $"Sub-speciality · {subSpeciality.Name}";
    // Specialities are national now (T091); College prefix lands with the Phase 5 admin rework.
    return $"Sub-speciality · {speciality.Name} / {subSpeciality.Name}";
  }
}
