@page "/admin/forms"
@attribute [Authorize(Policy = "AdministratorOrInstitutionalAdmin")]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Assessment Forms</PageTitle>

<PageHeader Title="Assessment forms" Subtitle="Manage the form shells, criteria, and EPA links used in assessments.">
  <Actions>
    <a class="btn btn-primary" href="/admin/forms/new">
      <Icon Name="plus" />
      Create form
    </a>
  </Actions>
</PageHeader>

<StatePanel IsLoading="@(_forms is null && string.IsNullOrWhiteSpace(_errorMessage))" LoadError="@_errorMessage" IsEmpty="@(_forms?.Count == 0)" EmptyTitle="No assessment forms yet" EmptyBody="Create the first form before linking it into assessment workflows.">
  @if (_forms is not null)
  {
    <DataTable TItem="AssessmentFormDto" Items="_forms" Caption="Assessment forms">
      <HeaderRow>
        <tr>
          <th>Name</th>
          <th>Scale</th>
          <th>Criteria</th>
          <th>EPA links</th>
          <th>Status</th>
          <th></th>
        </tr>
      </HeaderRow>
      <Row Context="form">
        <tr>
          <td>@form.Name</td>
          <td>@form.ScaleName</td>
          <td>@form.Criteria.Count</td>
          <td>@form.EpaLinks.Count</td>
          <td>@(form.IsActive ? "Active" : "Inactive")</td>
          <td><a class="btn btn-outline btn-sm" href="@($"/admin/forms/{form.Id}")">Edit</a></td>
        </tr>
      </Row>
    </DataTable>
  }
</StatePanel>

@code {
  private IReadOnlyList<AssessmentFormDto>? _forms;
  private string? _errorMessage;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _forms = await Sender.Send(new GetAssessmentFormsListQuery(authState.User));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
  }
}
