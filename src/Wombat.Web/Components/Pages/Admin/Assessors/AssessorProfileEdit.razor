@page "/admin/assessors/edit"
@attribute [Authorize(Policy = "AdministratorOrInstitutionalAdmin")]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Assessor Profile</PageTitle>

<PageHeader Title="Assessor profile" Subtitle="Assign the assessor to an institution and optional speciality scope.">
  <Actions>
    <a class="btn btn-outline btn-sm" href="/admin/assessors">Back to assessors</a>
  </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(_actionError))
{
  <Alert Kind="danger">@_actionError</Alert>
}

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
  <Alert Kind="success">@_statusMessage</Alert>
}

<StatePanel IsLoading="_loading" IsEmpty="@(_model is null)" EmptyTitle="Profile unavailable" EmptyBody="The assessor profile could not be loaded." LoadError="@_loadError">
  @if (_model is not null)
  {
    <div class="form-container">
      <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="assessor-profile">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary-errors" />

        <div class="form-grid form-grid--wide">
          <FormField Label="Assessor user" InputId="assessor-user-id" Required="true">
            <InputSelect id="assessor-user-id" class="form-select" @bind-Value="_model.UserId" disabled="@_isExisting">
              <option value="">Select assessor</option>
              @foreach (var user in _assessorUsers)
              {
                <option value="@user.UserId">@($"{user.FirstName} {user.LastName} ({user.Email})")</option>
              }
            </InputSelect>
          </FormField>

          <FormField Label="Institution" InputId="assessor-institution-id" Required="true">
            <InputSelect id="assessor-institution-id" class="form-select" @bind-Value="_model.InstitutionId">
              @foreach (var institution in _institutions)
              {
                <option value="@institution.Id">@institution.Name</option>
              }
            </InputSelect>
          </FormField>

          <FormField Label="Speciality" InputId="assessor-speciality-id">
            <InputSelect id="assessor-speciality-id" class="form-select" @bind-Value="_model.SpecialityId">
              <option value="">All</option>
              @foreach (var speciality in FilteredSpecialities)
              {
                <option value="@speciality.Id">@speciality.Name</option>
              }
            </InputSelect>
          </FormField>

          <FormField Label="Sub-speciality" InputId="assessor-sub-speciality-id">
            <InputSelect id="assessor-sub-speciality-id" class="form-select" @bind-Value="_model.SubSpecialityId" disabled="@(!_model.SpecialityId.HasValue)">
              <option value="">All</option>
              @foreach (var subSpeciality in FilteredSubSpecialities)
              {
                <option value="@subSpeciality.Id">@subSpeciality.Name</option>
              }
            </InputSelect>
          </FormField>

          <FormField Label="Qualifications" InputId="assessor-qualifications" Required="true" FullWidth="true">
            <InputTextArea id="assessor-qualifications" class="form-control" @bind-Value="_model.Qualifications" />
            <ValidationMessage For="() => _model.Qualifications" />
          </FormField>

          <FormField Label="Assessor training completed" InputId="assessor-training-completed">
            <InputDate id="assessor-training-completed" class="form-control" @bind-Value="_model.TrainingCompletedOn" />
            <small class="muted">Date the assessor completed assessor training. Leave blank if unrecorded.</small>
          </FormField>
        </div>

        <FormActions>
          <a class="btn btn-outline" href="/admin/assessors">Cancel</a>
          <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Saving..." : "Save assessor profile")</button>
        </FormActions>
      </EditForm>
    </div>
  }
</StatePanel>

@code {
  [SupplyParameterFromQuery(Name = "id")]
  public int? Id { get; set; }

  private IReadOnlyList<InstitutionDto> _institutions = [];
  private IReadOnlyList<SpecialityDto> _specialities = [];
  private IReadOnlyList<SubSpecialityDto> _subSpecialities = [];
  private IReadOnlyList<AssessorUserDto> _assessorUsers = [];
  private AssessorProfileFormModel? _model;
  private bool _loading = true;
  private bool _saving;
  private bool _isExisting;
  private string? _loadError;
  private string? _actionError;
  private string? _statusMessage;

  private IEnumerable<SpecialityDto> FilteredSpecialities
    => _specialities.Where(entity => entity.InstitutionId == _model?.InstitutionId);

  private IEnumerable<SubSpecialityDto> FilteredSubSpecialities
    => _subSpecialities.Where(entity => entity.SpecialityId == _model?.SpecialityId);

  protected override async Task OnParametersSetAsync()
  {
    _loading = true;
    _loadError = null;
    _actionError = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _institutions = await Sender.Send(new GetInstitutionsListQuery(authState.User));
      _specialities = await Sender.Send(new GetSpecialitiesListQuery(authState.User));
      _subSpecialities = await Sender.Send(new GetSubSpecialitiesListQuery(authState.User));
      _assessorUsers = await Sender.Send(new ListAssessorUsersQuery(authState.User));

      if (Id.HasValue)
      {
        var profile = await Sender.Send(new GetAssessorProfileByIdQuery(Id.Value, authState.User));
        _isExisting = true;
        _model = new AssessorProfileFormModel
        {
          UserId = profile.UserId,
          InstitutionId = profile.InstitutionId,
          SpecialityId = profile.SpecialityId,
          SubSpecialityId = profile.SubSpecialityId,
          Qualifications = profile.Qualifications,
          TrainingCompletedOn = profile.TrainingCompletedOn
        };
      }
      else
      {
        _model = new AssessorProfileFormModel
        {
          InstitutionId = _institutions.FirstOrDefault()?.Id ?? 0
        };
      }
    }
    catch (Exception exception)
    {
      _loadError = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task SaveAsync()
  {
    if (_model is null)
    {
      return;
    }

    _saving = true;
    _actionError = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      await Sender.Send(new CreateOrUpdateAssessorProfileCommand(
        _model.UserId,
        _model.Qualifications,
        _model.InstitutionId,
        _model.SpecialityId,
        _model.SubSpecialityId,
        _model.TrainingCompletedOn,
        authState.User));

      _statusMessage = "Assessor profile saved.";
      _isExisting = true;
    }
    catch (Exception exception)
    {
      _actionError = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private sealed class AssessorProfileFormModel
  {
    [Required]
    public string UserId { get; set; } = string.Empty;

    [Required]
    [Range(1, int.MaxValue)]
    public int InstitutionId { get; set; }

    public int? SpecialityId { get; set; }
    public int? SubSpecialityId { get; set; }

    [Required]
    [MaxLength(4000)]
    public string Qualifications { get; set; } = string.Empty;

    public DateOnly? TrainingCompletedOn { get; set; }
  }
}
