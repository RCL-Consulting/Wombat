@page "/admin/specialities/{SpecialityId:int}/sub-specialities/new"
@page "/admin/specialities/{SpecialityId:int}/sub-specialities/{Id:int}"
@attribute [Authorize(Policy = "AdministratorOrInstitutionalAdmin")]
@inject IScopedSender Sender
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@using Wombat.Application.Features.Epas

<PageTitle>@(IsNew ? "Create Sub-Speciality" : "Edit Sub-Speciality")</PageTitle>

<PageHeader Title="@(IsNew ? "Create sub-speciality" : "Edit sub-speciality")" Subtitle="@(_speciality is null ? "Scope this sub-speciality under the selected speciality." : $"Speciality: {_speciality.Name}")">
  <Actions>
    <a class="btn btn-outline btn-sm" href="@($"/admin/specialities/{SpecialityId}/sub-specialities")">Back to sub-specialities</a>
  </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
  <Alert Kind="success">@_statusMessage</Alert>
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
  <Alert Kind="danger">@_errorMessage</Alert>
}

<StatePanel IsLoading="_loading" IsEmpty="false" EmptyTitle="" EmptyBody="">
  <div class="form-container">
    <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="sub-speciality-edit">
      <DataAnnotationsValidator />
      <ValidationSummary class="validation-summary-errors" />

      <div class="form-grid">
        <FormField Label="Name" InputId="sub-speciality-name" Required="true">
          <InputText id="sub-speciality-name" class="form-control" @bind-Value="_model.Name" />
          <ValidationMessage For="() => _model.Name" />
        </FormField>

        <FormField Label="Description" InputId="sub-speciality-description" FullWidth="true">
          <InputTextArea id="sub-speciality-description" class="form-control" @bind-Value="_model.Description" />
          <ValidationMessage For="() => _model.Description" />
        </FormField>

        @if (!IsNew)
        {
          <FormField Label="Default entrustment scale" InputId="sub-speciality-scale" FullWidth="true">
            <InputSelect id="sub-speciality-scale" class="form-select" @bind-Value="_model.DefaultEntrustmentScaleId">
              <option value="">No default — offer every scale</option>
              @foreach (var scale in _scales)
              {
                <option value="@scale.Id">@scale.Name</option>
              }
            </InputSelect>
            <p class="form-hint">Committee STARs for this programme's trainees are limited to this scale's levels.</p>
          </FormField>

          <FormField Label="Status" InputId="sub-speciality-active">
            <div class="form-check">
              <InputCheckbox id="sub-speciality-active" class="form-check-input" @bind-Value="_model.IsActive" />
              <label for="sub-speciality-active">Active</label>
            </div>
          </FormField>
        }
      </div>

      <FormActions>
        <a class="btn btn-outline" href="@($"/admin/specialities/{SpecialityId}/sub-specialities")">Cancel</a>
        @if (!IsNew)
        {
          <button type="button" class="btn btn-danger" @onclick="DeactivateAsync" disabled="@_saving">Deactivate</button>
        }
        <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
      </FormActions>
    </EditForm>
  </div>
</StatePanel>

@code {
  [Parameter]
  public int SpecialityId { get; set; }

  [Parameter]
  public int? Id { get; set; }

  private SpecialityDto? _speciality;
  private IReadOnlyList<EntrustmentScaleDto> _scales = Array.Empty<EntrustmentScaleDto>();
  private SubSpecialityFormModel _model = new();
  private string? _errorMessage;
  private string? _statusMessage;
  private bool _loading;
  private bool _saving;

  private bool IsNew => !Id.HasValue;

  protected override async Task OnParametersSetAsync()
  {
    _loading = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _speciality = await FindSpecialityAsync(SpecialityId, authState.User);

      if (_speciality is null)
      {
        Navigation.NavigateTo("/not-found");
        return;
      }

      if (IsNew)
      {
        _model = new SubSpecialityFormModel { IsActive = true };
        return;
      }

      _scales = await Sender.Send(new GetEntrustmentScalesListQuery());

      var subSpecialities = await Sender.Send(new GetSubSpecialitiesForSpecialityQuery(SpecialityId, authState.User));
      var subSpecialityId = Id!.Value;
      var subSpeciality = subSpecialities.SingleOrDefault(item => item.Id == subSpecialityId);

      if (subSpeciality is null)
      {
        Navigation.NavigateTo("/not-found");
        return;
      }

      _model = new SubSpecialityFormModel
      {
        Name = subSpeciality.Name,
        Description = subSpeciality.Description,
        IsActive = subSpeciality.IsActive,
        DefaultEntrustmentScaleId = subSpeciality.DefaultEntrustmentScaleId
      };
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task SaveAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      SubSpecialityDto subSpeciality;

      if (IsNew)
      {
        subSpeciality = await Sender.Send(new CreateSubSpecialityCommand(SpecialityId, _model.Name, EmptyToNull(_model.Description), authState.User));
        Navigation.NavigateTo($"/admin/specialities/{SpecialityId}/sub-specialities/{subSpeciality.Id}", forceLoad: true);
        return;
      }

      subSpeciality = await Sender.Send(new UpdateSubSpecialityCommand(Id!.Value, SpecialityId, _model.Name, EmptyToNull(_model.Description), _model.IsActive, _model.DefaultEntrustmentScaleId, authState.User));
      _model.IsActive = subSpeciality.IsActive;
      _model.DefaultEntrustmentScaleId = subSpeciality.DefaultEntrustmentScaleId;
      _statusMessage = "Sub-speciality saved.";
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private async Task DeactivateAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      await Sender.Send(new DeactivateSubSpecialityCommand(Id!.Value, authState.User));
      _model.IsActive = false;
      _statusMessage = "Sub-speciality deactivated.";
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private async Task<SpecialityDto?> FindSpecialityAsync(int specialityId, System.Security.Claims.ClaimsPrincipal principal)
  {
    var institutions = await Sender.Send(new GetInstitutionsListQuery(principal));

    foreach (var institution in institutions)
    {
      var specialities = await Sender.Send(new GetSpecialitiesForInstitutionQuery(institution.Id, principal));
      var speciality = specialities.SingleOrDefault(item => item.Id == specialityId);

      if (speciality is not null)
      {
        return speciality;
      }
    }

    return null;
  }

  private static string? EmptyToNull(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

  private sealed class SubSpecialityFormModel
  {
    [Required]
    [StringLength(200)]
    public string Name { get; set; } = string.Empty;

    [StringLength(2000)]
    public string? Description { get; set; }

    public bool IsActive { get; set; } = true;

    public int? DefaultEntrustmentScaleId { get; set; }
  }
}
