@page "/admin/institutions/new"
@page "/admin/institutions/{Id:int}"
@attribute [Authorize(Policy = "Administrator")]
@inject IScopedSender Sender
@inject NavigationManager Navigation

<PageTitle>@(IsNew ? "Create Institution" : "Edit Institution")</PageTitle>

<h1>@(IsNew ? "Create institution" : "Edit institution")</h1>

<p>
    <a href="/admin/institutions">Back to institutions</a>
    @if (!IsNew)
    {
        <span> | </span>
        <a href="@($"/admin/institutions/{Id}/specialities")">Manage specialities</a>
    }
</p>

@if (_loading)
{
    <p>Loading institution...</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <p>@_statusMessage</p>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p>@_errorMessage</p>
    }

    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="institution-name">Name</label>
            <InputText id="institution-name" class="form-control" @bind-Value="_model.Name" />
        </div>

        <div class="mb-3">
            <label for="institution-short-code">Short code</label>
            <InputText id="institution-short-code" class="form-control" @bind-Value="_model.ShortCode" />
        </div>

        <div class="mb-3">
            <label for="institution-email">Contact email</label>
            <InputText id="institution-email" class="form-control" @bind-Value="_model.ContactEmail" />
        </div>

        @if (!IsNew)
        {
            <div class="mb-3">
                <label>
                    <InputCheckbox @bind-Value="_model.IsActive" />
                    Active
                </label>
            </div>
        }

        <button type="submit" class="btn btn-primary">@(_saving ? "Saving..." : "Save")</button>
        @if (!IsNew)
        {
            <button type="button" class="btn btn-outline-danger ms-2" @onclick="DeactivateAsync" disabled="@_saving">Deactivate</button>
        }
    </EditForm>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private InstitutionFormModel _model = new();
    private string? _errorMessage;
    private string? _statusMessage;
    private bool _loading;
    private bool _saving;

    private bool IsNew => !Id.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        _errorMessage = null;
        _statusMessage = null;

        if (IsNew)
        {
            _model = new InstitutionFormModel { IsActive = true };
            return;
        }

        _loading = true;

        try
        {
            var institution = await Sender.Send(new GetInstitutionByIdQuery(Id!.Value));

            if (institution is null)
            {
                Navigation.NavigateTo("/not-found");
                return;
            }

            _model = new InstitutionFormModel
            {
                Name = institution.Name,
                ShortCode = institution.ShortCode,
                ContactEmail = institution.ContactEmail,
                IsActive = institution.IsActive
            };
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _errorMessage = null;
        _statusMessage = null;

        try
        {
            InstitutionDto institution;

            if (IsNew)
            {
                institution = await Sender.Send(new CreateInstitutionCommand(_model.Name, _model.ShortCode, EmptyToNull(_model.ContactEmail)));
                Navigation.NavigateTo($"/admin/institutions/{institution.Id}");
                return;
            }

            institution = await Sender.Send(new UpdateInstitutionCommand(Id!.Value, _model.Name, _model.ShortCode, EmptyToNull(_model.ContactEmail), _model.IsActive));
            _model.IsActive = institution.IsActive;
            _statusMessage = "Institution saved.";
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeactivateAsync()
    {
        _saving = true;
        _errorMessage = null;
        _statusMessage = null;

        try
        {
            await Sender.Send(new DeactivateInstitutionCommand(Id!.Value));
            _model.IsActive = false;
            _statusMessage = "Institution deactivated.";
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private static string? EmptyToNull(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class InstitutionFormModel
    {
        [Required]
        [StringLength(200)]
        public string Name { get; set; } = string.Empty;

        [Required]
        [StringLength(32)]
        public string ShortCode { get; set; } = string.Empty;

        [StringLength(320)]
        public string? ContactEmail { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
