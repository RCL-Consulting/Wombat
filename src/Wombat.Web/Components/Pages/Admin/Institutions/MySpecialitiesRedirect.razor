@page "/admin/specialities"
@attribute [Authorize(Policy = "AdministratorOrCollegeAdmin")]
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@using Wombat.Application.Common.Extensions

@*
  Specialities are College-owned (T091). This redirect lets the CollegeAdmin "Specialities" nav link work
  without knowing the user's college id at render time. Administrators are bounced to the colleges list —
  they pick which college's specialities to manage from there.
*@

<StatePanel IsLoading="true" IsEmpty="false" EmptyTitle="" EmptyBody="">
  <p class="muted">Redirecting...</p>
</StatePanel>

@code {
  protected override async Task OnInitializedAsync()
  {
    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    var collegeId = authState.User.GetCollegeId();

    if (collegeId.HasValue)
    {
      Navigation.NavigateTo($"/admin/colleges/{collegeId.Value}/specialities", forceLoad: false);
      return;
    }

    Navigation.NavigateTo("/admin/colleges", forceLoad: false);
  }
}
