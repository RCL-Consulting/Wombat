@page "/admin/specialities/{SpecialityId:int}/sub-specialities"
@attribute [Authorize(Policy = "Administrator")]
@inject IScopedSender Sender

<PageTitle>Sub-Specialities</PageTitle>

<PageHeader Title="Sub-specialities" Subtitle="@(_speciality is null ? "Manage sub-specialities for the selected speciality." : $"Speciality: {_speciality.Name}")">
  <Actions>
    @if (_speciality is not null)
    {
      <a class="btn btn-outline btn-sm" href="@($"/admin/institutions/{_speciality.InstitutionId}/specialities")">Back to specialities</a>
    }
    <a class="btn btn-primary btn-sm" href="@($"/admin/specialities/{SpecialityId}/sub-specialities/new")">
      <Icon Name="plus" />
      Create sub-speciality
    </a>
  </Actions>
</PageHeader>

<StatePanel IsLoading="@(_subSpecialities is null && string.IsNullOrWhiteSpace(_errorMessage))" LoadError="@_errorMessage" IsEmpty="@(_subSpecialities?.Count == 0)" EmptyTitle="No sub-specialities yet" EmptyBody="Create the first sub-speciality under this speciality.">
  @if (_subSpecialities is not null)
  {
    <DataTable TItem="SubSpecialityDto" Items="_subSpecialities" Caption="Sub-specialities">
      <HeaderRow>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Status</th>
          <th></th>
        </tr>
      </HeaderRow>
      <Row Context="subSpeciality">
        <tr>
          <td>@subSpeciality.Name</td>
          <td>@subSpeciality.Description</td>
          <td>@(subSpeciality.IsActive ? "Active" : "Inactive")</td>
          <td>
            <a class="btn btn-outline btn-sm" href="@($"/admin/specialities/{SpecialityId}/sub-specialities/{subSpeciality.Id}")">Edit</a>
          </td>
        </tr>
      </Row>
    </DataTable>
  }
</StatePanel>

@code {
  [Parameter]
  public int SpecialityId { get; set; }

  private SpecialityDto? _speciality;
  private IReadOnlyList<SubSpecialityDto>? _subSpecialities;
  private string? _errorMessage;

  protected override async Task OnParametersSetAsync()
  {
    _errorMessage = null;

    try
    {
      _speciality = await FindSpecialityAsync(SpecialityId);
      _subSpecialities = await Sender.Send(new GetSubSpecialitiesForSpecialityQuery(SpecialityId));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
  }

  private async Task<SpecialityDto?> FindSpecialityAsync(int specialityId)
  {
    var institutions = await Sender.Send(new GetInstitutionsListQuery());

    foreach (var institution in institutions)
    {
      var specialities = await Sender.Send(new GetSpecialitiesForInstitutionQuery(institution.Id));
      var speciality = specialities.SingleOrDefault(item => item.Id == specialityId);

      if (speciality is not null)
      {
        return speciality;
      }
    }

    return null;
  }
}
