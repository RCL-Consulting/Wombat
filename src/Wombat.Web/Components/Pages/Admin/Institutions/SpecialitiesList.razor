@page "/admin/institutions/{InstitutionId:int}/specialities"
@attribute [Authorize(Policy = "Administrator")]
@inject IScopedSender Sender

<PageTitle>Specialities</PageTitle>

<PageHeader Title="Specialities" Subtitle="@(_institution is null ? "Manage specialities for the selected institution." : $"Institution: {_institution.Name} ({_institution.ShortCode})")">
  <Actions>
    <a class="btn btn-outline btn-sm" href="/admin/institutions">Back to institutions</a>
    <a class="btn btn-primary btn-sm" href="@($"/admin/institutions/{InstitutionId}/specialities/new")">
      <Icon Name="plus" />
      Create speciality
    </a>
  </Actions>
</PageHeader>

<StatePanel IsLoading="@(_specialities is null && string.IsNullOrWhiteSpace(_errorMessage))" LoadError="@_errorMessage" IsEmpty="@(_specialities?.Count == 0)" EmptyTitle="No specialities yet" EmptyBody="Create the first speciality for this institution.">
  @if (_specialities is not null)
  {
    <DataTable TItem="SpecialityDto" Items="_specialities" Caption="Specialities">
      <HeaderRow>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Status</th>
          <th></th>
        </tr>
      </HeaderRow>
      <Row Context="speciality">
        <tr>
          <td>@speciality.Name</td>
          <td>@speciality.Description</td>
          <td>@(speciality.IsActive ? "Active" : "Inactive")</td>
          <td>
            <div class="actions-cell">
              <a class="btn btn-outline btn-sm" href="@($"/admin/institutions/{InstitutionId}/specialities/{speciality.Id}")">Edit</a>
              <a class="btn btn-outline btn-sm" href="@($"/admin/specialities/{speciality.Id}/sub-specialities")">Sub-specialities</a>
            </div>
          </td>
        </tr>
      </Row>
    </DataTable>
  }
</StatePanel>

@code {
  [Parameter]
  public int InstitutionId { get; set; }

  private InstitutionDto? _institution;
  private IReadOnlyList<SpecialityDto>? _specialities;
  private string? _errorMessage;

  protected override async Task OnParametersSetAsync()
  {
    _errorMessage = null;

    try
    {
      _institution = await Sender.Send(new GetInstitutionByIdQuery(InstitutionId));
      _specialities = await Sender.Send(new GetSpecialitiesForInstitutionQuery(InstitutionId));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
  }
}
