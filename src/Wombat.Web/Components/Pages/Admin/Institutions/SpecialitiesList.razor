@page "/admin/colleges/{CollegeId:int}/specialities"
@attribute [Authorize(Policy = "AdministratorOrCollegeAdmin")]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Specialities</PageTitle>

<PageHeader Title="Specialities" Subtitle="@(_college is null ? "Manage specialities for the selected college." : $"College: {_college.Name} ({_college.ShortCode})")">
  <Actions>
    <a class="btn btn-outline btn-sm" href="/admin/colleges">Back to colleges</a>
    <a class="btn btn-primary btn-sm" href="@($"/admin/colleges/{CollegeId}/specialities/new")">
      <Icon Name="plus" />
      Create speciality
    </a>
  </Actions>
</PageHeader>

<StatePanel IsLoading="@(_specialities is null && string.IsNullOrWhiteSpace(_errorMessage))" LoadError="@_errorMessage" IsEmpty="@(_specialities?.Count == 0)" EmptyTitle="No specialities yet" EmptyBody="Create the first speciality for this college.">
  @if (_specialities is not null)
  {
    <DataTable TItem="SpecialityDto" Items="_specialities" Caption="Specialities">
      <HeaderRow>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Status</th>
          <th></th>
        </tr>
      </HeaderRow>
      <Row Context="speciality">
        <tr>
          <td>@speciality.Name</td>
          <td>@speciality.Description</td>
          <td>@(speciality.IsActive ? "Active" : "Inactive")</td>
          <td>
            <div class="actions-cell">
              <a class="btn btn-outline btn-sm" href="@($"/admin/colleges/{CollegeId}/specialities/{speciality.Id}")">Edit</a>
              <a class="btn btn-outline btn-sm" href="@($"/admin/specialities/{speciality.Id}/sub-specialities")">Sub-specialities</a>
            </div>
          </td>
        </tr>
      </Row>
    </DataTable>
  }
</StatePanel>

@code {
  [Parameter]
  public int CollegeId { get; set; }

  private CollegeDto? _college;
  private IReadOnlyList<SpecialityDto>? _specialities;
  private string? _errorMessage;

  protected override async Task OnParametersSetAsync()
  {
    _errorMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _college = await Sender.Send(new GetCollegeByIdQuery(CollegeId, authState.User));
      _specialities = await Sender.Send(new GetSpecialitiesForInstitutionQuery(CollegeId, authState.User));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
  }
}
