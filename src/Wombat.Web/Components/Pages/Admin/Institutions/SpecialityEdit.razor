@page "/admin/institutions/{InstitutionId:int}/specialities/new"
@page "/admin/institutions/{InstitutionId:int}/specialities/{Id:int}"
@attribute [Authorize(Policy = "AdministratorOrInstitutionalAdmin")]
@inject IScopedSender Sender
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(IsNew ? "Create Speciality" : "Edit Speciality")</PageTitle>

<PageHeader Title="@(IsNew ? "Create speciality" : "Edit speciality")" Subtitle="@(_institution is null ? "Scope this speciality under the current institution." : $"Institution: {_institution.Name} ({_institution.ShortCode})")">
  <Actions>
    <a class="btn btn-outline btn-sm" href="@($"/admin/institutions/{InstitutionId}/specialities")">Back to specialities</a>
    @if (!IsNew && Id.HasValue)
    {
      <a class="btn btn-outline btn-sm" href="@($"/admin/specialities/{Id.Value}/sub-specialities")">Manage sub-specialities</a>
    }
  </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
  <Alert Kind="success">@_statusMessage</Alert>
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
  <Alert Kind="danger">@_errorMessage</Alert>
}

<StatePanel IsLoading="_loading" IsEmpty="false" EmptyTitle="" EmptyBody="">
  <div class="form-container">
    <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="speciality-edit">
      <DataAnnotationsValidator />
      <ValidationSummary class="validation-summary-errors" />

      <div class="form-grid">
        <FormField Label="Name" InputId="speciality-name" Required="true">
          <InputText id="speciality-name" class="form-control" @bind-Value="_model.Name" />
          <ValidationMessage For="() => _model.Name" />
        </FormField>

        <FormField Label="Description" InputId="speciality-description" FullWidth="true">
          <InputTextArea id="speciality-description" class="form-control" @bind-Value="_model.Description" />
          <ValidationMessage For="() => _model.Description" />
        </FormField>

        @if (!IsNew)
        {
          <FormField Label="Status" InputId="speciality-active">
            <div class="form-check">
              <InputCheckbox id="speciality-active" class="form-check-input" @bind-Value="_model.IsActive" />
              <label for="speciality-active">Active</label>
            </div>
          </FormField>
        }
      </div>

      <FormActions>
        <a class="btn btn-outline" href="@($"/admin/institutions/{InstitutionId}/specialities")">Cancel</a>
        @if (!IsNew)
        {
          <button type="button" class="btn btn-danger" @onclick="DeactivateAsync" disabled="@_saving">Deactivate</button>
        }
        <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
      </FormActions>
    </EditForm>
  </div>
</StatePanel>

@code {
  [Parameter]
  public int InstitutionId { get; set; }

  [Parameter]
  public int? Id { get; set; }

  private InstitutionDto? _institution;
  private SpecialityFormModel _model = new();
  private string? _errorMessage;
  private string? _statusMessage;
  private bool _loading;
  private bool _saving;

  private bool IsNew => !Id.HasValue;

  protected override async Task OnParametersSetAsync()
  {
    _loading = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _institution = await Sender.Send(new GetInstitutionByIdQuery(InstitutionId, authState.User));

      if (_institution is null)
      {
        Navigation.NavigateTo("/not-found");
        return;
      }

      if (IsNew)
      {
        _model = new SpecialityFormModel { IsActive = true };
        return;
      }

      var specialities = await Sender.Send(new GetSpecialitiesForInstitutionQuery(InstitutionId, authState.User));
      var specialityId = Id!.Value;
      var speciality = specialities.SingleOrDefault(item => item.Id == specialityId);

      if (speciality is null)
      {
        Navigation.NavigateTo("/not-found");
        return;
      }

      _model = new SpecialityFormModel
      {
        Name = speciality.Name,
        Description = speciality.Description,
        IsActive = speciality.IsActive
      };
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task SaveAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      SpecialityDto speciality;

      if (IsNew)
      {
        speciality = await Sender.Send(new CreateSpecialityCommand(InstitutionId, _model.Name, EmptyToNull(_model.Description), authState.User));
        Navigation.NavigateTo($"/admin/institutions/{InstitutionId}/specialities/{speciality.Id}");
        return;
      }

      speciality = await Sender.Send(new UpdateSpecialityCommand(Id!.Value, InstitutionId, _model.Name, EmptyToNull(_model.Description), _model.IsActive, authState.User));
      _model.IsActive = speciality.IsActive;
      _statusMessage = "Speciality saved.";
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private async Task DeactivateAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      await Sender.Send(new DeactivateSpecialityCommand(Id!.Value, authState.User));
      _model.IsActive = false;
      _statusMessage = "Speciality deactivated.";
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private static string? EmptyToNull(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

  private sealed class SpecialityFormModel
  {
    [Required]
    [StringLength(200)]
    public string Name { get; set; } = string.Empty;

    [StringLength(2000)]
    public string? Description { get; set; }

    public bool IsActive { get; set; } = true;
  }
}
