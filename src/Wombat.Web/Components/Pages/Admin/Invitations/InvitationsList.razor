@page "/admin/invitations"
@attribute [Authorize(Policy = "AdministratorOrInstitutionalAdmin")]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IOptions<Wombat.Application.Common.Options.WombatOptions> WombatOptionsAccessor
@using Microsoft.Extensions.Options

<PageTitle>Invitations</PageTitle>

<PageHeader Title="Invitations" Subtitle="Issue invitation-only onboarding links and review active invitations." />

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
  <Alert Kind="success">@_statusMessage</Alert>
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
  <Alert Kind="danger">@_errorMessage</Alert>
}

@if (!string.IsNullOrWhiteSpace(_lastIssuedRegistrationUrl))
{
  <Alert Kind="info">
    <p>
      <strong>Share this registration link with the invitee.</strong>
      It expires in 14 days. The link is shown here only on this page-load — copy it now;
      it cannot be retrieved later. Email delivery is configured separately; if SMTP is not
      set up, this link is the canonical onboarding handoff.
    </p>
    <p>
      <code style="word-break:break-all">@_lastIssuedRegistrationUrl</code>
    </p>
  </Alert>
}

<div class="details-grid">
  <section class="detail-card">
    <h3>Issue invitation</h3>
    <EditForm Model="_model" OnValidSubmit="IssueAsync" FormName="issue-invitation">
      <DataAnnotationsValidator />
      <ValidationSummary class="validation-summary-errors" />

      <div class="form-grid form-grid--wide">
        <FormField Label="Email" InputId="invitation-email" Required="true">
          <InputText id="invitation-email" class="form-control" @bind-Value="_model.Email" />
          <ValidationMessage For="() => _model.Email" />
        </FormField>

        <FormField Label="Role" InputId="invitation-role" Required="true">
          <InputSelect id="invitation-role" class="form-select" @bind-Value="_model.TargetRole">
            @foreach (var role in AvailableRoles)
            {
              <option value="@role">@role</option>
            }
          </InputSelect>
        </FormField>

        @if (IsCollegeAdminRole)
        {
          <FormField Label="College" InputId="invitation-college" Required="true">
            <InputSelect id="invitation-college" class="form-select" @bind-Value="_model.CollegeId">
              <option value="">Select college</option>
              @foreach (var college in _colleges)
              {
                <option value="@college.Id">@college.Name</option>
              }
            </InputSelect>
          </FormField>
        }
        else
        {
          <FormField Label="Institution" InputId="invitation-institution" Required="true">
            <InputSelect id="invitation-institution" class="form-select" @bind-Value="_model.InstitutionId">
              <option value="">Select institution</option>
              @foreach (var institution in _institutions)
              {
                <option value="@institution.Id">@institution.Name</option>
              }
            </InputSelect>
          </FormField>
        }

        <FormField Label="Speciality" InputId="invitation-speciality">
          <InputSelect id="invitation-speciality" class="form-select" @bind-Value="_model.SpecialityId" disabled="@(!RequiresSpeciality)">
            <option value="">Select speciality</option>
            @foreach (var speciality in FilteredSpecialities)
            {
              <option value="@speciality.Id">@speciality.Name</option>
            }
          </InputSelect>
        </FormField>

        <FormField Label="Sub-speciality" InputId="invitation-sub-speciality">
          <InputSelect id="invitation-sub-speciality" class="form-select" @bind-Value="_model.SubSpecialityId" disabled="@(!RequiresSubSpeciality)">
            <option value="">Select sub-speciality</option>
            @foreach (var subSpeciality in FilteredSubSpecialities)
            {
              <option value="@subSpeciality.Id">@subSpeciality.Name</option>
            }
          </InputSelect>
        </FormField>
      </div>

      <FormActions>
        <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Issuing..." : "Issue invitation")</button>
      </FormActions>
    </EditForm>
  </section>

  <section class="detail-card">
    <h3>Active invitations</h3>
    <StatePanel IsLoading="_loading" LoadError="@(null)" IsEmpty="@(_invitations.Count == 0)" EmptyTitle="No active invitations" EmptyBody="Issue an invitation to create the first onboarding link.">
      <DataTable TItem="ActiveInvitationDto" Items="_invitations" Caption="Active invitations">
        <HeaderRow>
          <tr>
            <th>Email</th>
            <th>Role</th>
            <th>Institution</th>
            <th>College</th>
            <th>Speciality</th>
            <th>Sub-speciality</th>
            <th>Issued</th>
            <th>Expires</th>
            <th></th>
          </tr>
        </HeaderRow>
        <Row Context="invitation">
          <tr>
            <td>@invitation.Email</td>
            <td>@invitation.TargetRole</td>
            <td>@invitation.InstitutionName</td>
            <td>@invitation.CollegeName</td>
            <td>@invitation.SpecialityName</td>
            <td>@invitation.SubSpecialityName</td>
            <td>@invitation.IssuedOn.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
            <td>@invitation.ExpiresOn.ToString("yyyy-MM-dd")</td>
            <td><button type="button" class="btn btn-danger btn-sm" @onclick="() => RevokeAsync(invitation.Id)">Revoke</button></td>
          </tr>
        </Row>
      </DataTable>
    </StatePanel>
  </section>
</div>

@code {
  private static readonly string[] _roles =
  [
    WombatRoles.CollegeAdmin,
    WombatRoles.InstitutionalAdmin,
    WombatRoles.SpecialityAdmin,
    WombatRoles.SubSpecialityAdmin,
    WombatRoles.Coordinator,
    WombatRoles.CommitteeMember,
    WombatRoles.Assessor,
    WombatRoles.Trainee
  ];

  private InvitationFormModel _model = new();
  private IReadOnlyList<InstitutionDto> _institutions = [];
  private IReadOnlyList<CollegeDto> _colleges = [];
  private IReadOnlyList<SpecialityDto> _specialities = [];
  private IReadOnlyList<SubSpecialityDto> _subSpecialities = [];
  private IReadOnlyList<ActiveInvitationDto> _invitations = [];
  private bool _isAdministrator;
  private string? _statusMessage;
  private string? _errorMessage;
  private string? _lastIssuedRegistrationUrl;
  private bool _loading = true;
  private bool _saving;

  // Only a global Administrator may provision a CollegeAdmin (the handler enforces this too);
  // hide the option from InstitutionalAdmins so they aren't offered a path that will be rejected. (T093)
  private IEnumerable<string> AvailableRoles
    => _isAdministrator ? _roles : _roles.Where(role => role != WombatRoles.CollegeAdmin);

  private bool IsCollegeAdminRole => _model.TargetRole == WombatRoles.CollegeAdmin;

  private bool RequiresSpeciality
    => _model.TargetRole is WombatRoles.SpecialityAdmin or WombatRoles.SubSpecialityAdmin or WombatRoles.Coordinator or WombatRoles.CommitteeMember or WombatRoles.Assessor or WombatRoles.Trainee;

  private bool RequiresSubSpeciality
    => _model.TargetRole is WombatRoles.SubSpecialityAdmin or WombatRoles.Assessor or WombatRoles.Trainee;

  // Specialities are a national catalogue now (T091); not filtered by the selected institution.
  private IEnumerable<SpecialityDto> FilteredSpecialities => _specialities;

  private IEnumerable<SubSpecialityDto> FilteredSubSpecialities
    => _subSpecialities.Where(entity => _model.SpecialityId.HasValue && entity.SpecialityId == _model.SpecialityId.Value);

  protected override async Task OnInitializedAsync()
  {
    await LoadAsync();
  }

  private async Task LoadAsync()
  {
    _loading = true;
    _errorMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _isAdministrator = authState.User.IsInRole(WombatRoles.Administrator);
      _institutions = await Sender.Send(new GetInstitutionsListQuery(authState.User));
      _colleges = await Sender.Send(new GetCollegesListQuery(authState.User));
      _specialities = await Sender.Send(new GetSpecialitiesListQuery(authState.User));
      _subSpecialities = await Sender.Send(new GetSubSpecialitiesListQuery(authState.User));
      _invitations = await Sender.Send(new ListActiveInvitationsQuery(authState.User));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task IssueAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      if (IsCollegeAdminRole)
      {
        // A CollegeAdmin is scoped to a college only.
        _model.InstitutionId = null;
        _model.SpecialityId = null;
        _model.SubSpecialityId = null;
      }
      else
      {
        _model.CollegeId = null;
        if (!RequiresSpeciality)
        {
          _model.SpecialityId = null;
          _model.SubSpecialityId = null;
        }
        else if (!RequiresSubSpeciality)
        {
          _model.SubSpecialityId = null;
        }
      }

      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      var issuedByUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
        ?? throw new InvalidOperationException("The current user identifier is missing.");

      var issued = await Sender.Send(new IssueInvitationCommand(
        _model.Email,
        _model.TargetRole,
        _model.InstitutionId,
        _model.CollegeId,
        _model.SpecialityId,
        _model.SubSpecialityId,
        issuedByUserId,
        authState.User));

      var baseUrl = (WombatOptionsAccessor.Value.BaseUrl ?? string.Empty).TrimEnd('/');
      _lastIssuedRegistrationUrl = $"{baseUrl}/account/register?token={Uri.EscapeDataString(issued.Token)}";
      _statusMessage = $"Invitation issued for {_model.Email}. Copy the link below — it is shown only once.";
      _model = new InvitationFormModel();
      _invitations = await Sender.Send(new ListActiveInvitationsQuery(authState.User));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private async Task RevokeAsync(int invitationId)
  {
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      await Sender.Send(new RevokeInvitationCommand(invitationId, authState.User));
      _statusMessage = "Invitation revoked.";
      _invitations = await Sender.Send(new ListActiveInvitationsQuery(authState.User));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
  }

  private sealed class InvitationFormModel
  {
    [Required]
    [EmailAddress]
    public string Email { get; set; } = string.Empty;

    [Required]
    public string TargetRole { get; set; } = WombatRoles.InstitutionalAdmin;

    // Institution (institution-scoped roles) vs College (CollegeAdmin) is validated server-side by
    // InvitationRules.ValidateScope, which depends on the chosen role. (T093)
    public int? InstitutionId { get; set; }
    public int? CollegeId { get; set; }

    public int? SpecialityId { get; set; }
    public int? SubSpecialityId { get; set; }
  }
}
