@page "/admin/epas"
@attribute [Authorize(Policy = "NationalCatalogueAccess")]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>EPAs</PageTitle>

<PageHeader Title="EPAs" Subtitle="Maintain the entrustable professional activities available to curricula and forms.">
  <Actions>
    <a class="btn btn-primary" href="/admin/epas/new">
      <Icon Name="plus" />
      Create EPA
    </a>
  </Actions>
</PageHeader>

<StatePanel IsLoading="@(_epas is null || _subSpecialities is null || _specialities is null || _institutions is null)" LoadError="@_errorMessage" IsEmpty="@(_epas?.Count == 0)" EmptyTitle="No EPAs yet" EmptyBody="Create the first EPA to start building curricula and assessment forms.">
  @if (_epas is not null && _subSpecialities is not null && _specialities is not null && _institutions is not null)
  {
    <DataTable TItem="EpaDto" Items="_epas" Caption="Entrustable professional activities">
      <HeaderRow>
        <tr>
          <th>Code</th>
          <th>Title</th>
          <th>College</th>
          <th>Speciality</th>
          <th>Sub-speciality</th>
          <th>Status</th>
          <th></th>
        </tr>
      </HeaderRow>
      <Row Context="epa">
        @{
          var subSpeciality = _subSpecialities.Single(entity => entity.Id == epa.SubSpecialityId);
          var speciality = _specialities.Single(entity => entity.Id == subSpeciality.SpecialityId);
        }
        <tr>
          <td>@epa.Code</td>
          <td>@epa.Title</td>
          <td>@epa.CollegeName</td>
          <td>@speciality.Name</td>
          <td>@subSpeciality.Name</td>
          <td>@(epa.IsActive ? "Active" : "Inactive")</td>
          <td>
            <a class="btn btn-outline btn-sm" href="@($"/admin/epas/{epa.Id}")">Edit</a>
          </td>
        </tr>
      </Row>
    </DataTable>
  }
</StatePanel>

@code {
  private IReadOnlyList<EpaDto>? _epas;
  private IReadOnlyList<InstitutionDto>? _institutions;
  private IReadOnlyList<SpecialityDto>? _specialities;
  private IReadOnlyList<SubSpecialityDto>? _subSpecialities;
  private string? _errorMessage;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _epas = await Sender.Send(new ListEpasForSubSpecialityQuery(authState.User));
      _institutions = await Sender.Send(new GetInstitutionsListQuery(authState.User));
      _specialities = await Sender.Send(new GetSpecialitiesListQuery(authState.User));
      _subSpecialities = await Sender.Send(new GetSubSpecialitiesListQuery(authState.User));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
  }
}
