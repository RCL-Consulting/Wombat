@page "/admin/epas"
@attribute [Authorize(Policy = "Administrator")]
@inject IScopedSender Sender

<PageTitle>EPAs</PageTitle>

<h1>EPAs</h1>

<p>
    <a href="/admin/epas/new">Create EPA</a>
</p>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <p>@_errorMessage</p>
}
else if (_epas is null || _subSpecialities is null || _specialities is null || _institutions is null)
{
    <p>Loading EPAs...</p>
}
else if (_epas.Count == 0)
{
    <p>No EPAs found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Title</th>
                <th>Institution</th>
                <th>Speciality</th>
                <th>Sub-speciality</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var epa in _epas)
            {
                var subSpeciality = _subSpecialities.Single(entity => entity.Id == epa.SubSpecialityId);
                var speciality = _specialities.Single(entity => entity.Id == subSpeciality.SpecialityId);
                var institution = _institutions.Single(entity => entity.Id == speciality.InstitutionId);

                <tr>
                    <td>@epa.Code</td>
                    <td>@epa.Title</td>
                    <td>@institution.Name</td>
                    <td>@speciality.Name</td>
                    <td>@subSpeciality.Name</td>
                    <td>@(epa.IsActive ? "Active" : "Inactive")</td>
                    <td><a href="@($"/admin/epas/{epa.Id}")">Edit</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<EpaDto>? _epas;
    private IReadOnlyList<InstitutionDto>? _institutions;
    private IReadOnlyList<SpecialityDto>? _specialities;
    private IReadOnlyList<SubSpecialityDto>? _subSpecialities;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _epas = await Sender.Send(new ListEpasForSubSpecialityQuery());
            _institutions = await Sender.Send(new GetInstitutionsListQuery());
            _specialities = await Sender.Send(new GetSpecialitiesListQuery());
            _subSpecialities = await Sender.Send(new GetSubSpecialitiesListQuery());
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
        }
    }
}
