@page "/admin/epas/new"
@page "/admin/epas/{Id:int}"
@attribute [Authorize(Policy = "Administrator")]
@inject IScopedSender Sender
@inject NavigationManager Navigation

<PageTitle>@(IsNew ? "Create EPA" : "Edit EPA")</PageTitle>

<PageHeader Title="@(IsNew ? "Create EPA" : "Edit EPA")" Subtitle="Define the EPA code, scope, and descriptive guidance." >
  <Actions>
    <a class="btn btn-outline btn-sm" href="/admin/epas">Back to EPAs</a>
  </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
  <Alert Kind="success">@_statusMessage</Alert>
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
  <Alert Kind="danger">@_errorMessage</Alert>
}

<StatePanel IsLoading="_loading" IsEmpty="false" EmptyTitle="" EmptyBody="">
  <div class="form-container">
    <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="epa-edit">
      <DataAnnotationsValidator />
      <ValidationSummary class="validation-summary-errors" />

      <div class="form-grid form-grid--wide">
        <FormField Label="Sub-speciality" InputId="epa-sub-speciality" Required="true">
          <InputSelect id="epa-sub-speciality" class="form-select" TValue="int" @bind-Value="_model.SubSpecialityId">
            @foreach (var option in SubSpecialityOptions)
            {
              <option value="@option.Id">@option.Label</option>
            }
          </InputSelect>
        </FormField>

        <FormField Label="Code" InputId="epa-code" Required="true">
          <InputText id="epa-code" class="form-control" @bind-Value="_model.Code" />
          <ValidationMessage For="() => _model.Code" />
        </FormField>

        <FormField Label="Title" InputId="epa-title" Required="true" FullWidth="true">
          <InputText id="epa-title" class="form-control" @bind-Value="_model.Title" />
          <ValidationMessage For="() => _model.Title" />
        </FormField>

        <FormField Label="Description" InputId="epa-description" FullWidth="true">
          <InputTextArea id="epa-description" class="form-control" @bind-Value="_model.Description" />
          <ValidationMessage For="() => _model.Description" />
        </FormField>

        <FormField Label="Required knowledge and skills" InputId="epa-rks" FullWidth="true">
          <InputTextArea id="epa-rks" class="form-control" @bind-Value="_model.RequiredKnowledgeSkills" />
          <ValidationMessage For="() => _model.RequiredKnowledgeSkills" />
        </FormField>

        <FormField Label="Category" InputId="epa-category" Required="true">
          <InputSelect id="epa-category" class="form-select" @bind-Value="_model.Category">
            @foreach (var category in Enum.GetValues<EpaCategory>())
            {
              <option value="@category">@category</option>
            }
          </InputSelect>
        </FormField>

        @if (!IsNew)
        {
          <FormField Label="Status" InputId="epa-active">
            <div class="form-check">
              <InputCheckbox id="epa-active" class="form-check-input" @bind-Value="_model.IsActive" />
              <label for="epa-active">Active</label>
            </div>
          </FormField>
        }
      </div>

      <FormActions>
        <a class="btn btn-outline" href="/admin/epas">Cancel</a>
        @if (!IsNew)
        {
          <button type="button" class="btn btn-danger" @onclick="DeactivateAsync" disabled="@_saving">Deactivate</button>
        }
        <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
      </FormActions>
    </EditForm>
  </div>
</StatePanel>

@code {
  [Parameter]
  public int? Id { get; set; }

  private readonly EpaFormModel _model = new();
  private IReadOnlyList<InstitutionDto> _institutions = [];
  private IReadOnlyList<SpecialityDto> _specialities = [];
  private IReadOnlyList<SubSpecialityDto> _subSpecialities = [];
  private string? _errorMessage;
  private string? _statusMessage;
  private bool _loading;
  private bool _saving;

  private bool IsNew => !Id.HasValue;

  private IEnumerable<LookupOption> SubSpecialityOptions =>
    from subSpeciality in _subSpecialities
    join speciality in _specialities on subSpeciality.SpecialityId equals speciality.Id
    join institution in _institutions on speciality.InstitutionId equals institution.Id
    select new LookupOption(subSpeciality.Id, $"{institution.Name} / {speciality.Name} / {subSpeciality.Name}");

  protected override async Task OnParametersSetAsync()
  {
    _loading = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      _institutions = await Sender.Send(new GetInstitutionsListQuery());
      _specialities = await Sender.Send(new GetSpecialitiesListQuery());
      _subSpecialities = await Sender.Send(new GetSubSpecialitiesListQuery());

      if (IsNew)
      {
        _model.SubSpecialityId = _subSpecialities.FirstOrDefault()?.Id ?? 0;
        _model.IsActive = true;
        return;
      }

      var epa = await Sender.Send(new GetEpaByIdQuery(Id!.Value));

      if (epa is null)
      {
        Navigation.NavigateTo("/not-found");
        return;
      }

      _model.SubSpecialityId = epa.SubSpecialityId;
      _model.Code = epa.Code;
      _model.Title = epa.Title;
      _model.Description = epa.Description;
      _model.RequiredKnowledgeSkills = epa.RequiredKnowledgeSkills;
      _model.Category = epa.Category;
      _model.IsActive = epa.IsActive;
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task SaveAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      EpaDto epa;

      if (IsNew)
      {
        epa = await Sender.Send(new CreateEpaCommand(_model.SubSpecialityId, _model.Code, _model.Title, EmptyToNull(_model.Description), EmptyToNull(_model.RequiredKnowledgeSkills), _model.Category));
        Navigation.NavigateTo($"/admin/epas/{epa.Id}");
        return;
      }

      epa = await Sender.Send(new UpdateEpaCommand(Id!.Value, _model.SubSpecialityId, _model.Code, _model.Title, EmptyToNull(_model.Description), EmptyToNull(_model.RequiredKnowledgeSkills), _model.Category, _model.IsActive));
      _model.IsActive = epa.IsActive;
      _statusMessage = "EPA saved.";
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private async Task DeactivateAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      await Sender.Send(new DeactivateEpaCommand(Id!.Value));
      _model.IsActive = false;
      _statusMessage = "EPA deactivated.";
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private static string? EmptyToNull(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

  private sealed class EpaFormModel
  {
    [Range(1, int.MaxValue)]
    public int SubSpecialityId { get; set; }

    [Required]
    [StringLength(64)]
    public string Code { get; set; } = string.Empty;

    [Required]
    [StringLength(200)]
    public string Title { get; set; } = string.Empty;

    [StringLength(4000)]
    public string? Description { get; set; }

    [StringLength(8000)]
    public string? RequiredKnowledgeSkills { get; set; }

    public EpaCategory Category { get; set; } = EpaCategory.Core;

    public bool IsActive { get; set; } = true;
  }

  private sealed record LookupOption(int Id, string Label);
}
