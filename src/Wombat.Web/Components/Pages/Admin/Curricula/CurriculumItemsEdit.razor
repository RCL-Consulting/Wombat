@page "/admin/curricula/{Id:int}/items"
@attribute [Authorize(Policy = "AdministratorOrInstitutionalAdmin")]
@inject IScopedSender Sender
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Curriculum Items</PageTitle>

<PageHeader Title="Curriculum items" Subtitle="@(_curriculum is null ? "Manage EPA requirements for the selected curriculum." : $"{_curriculum.Name} ({_curriculum.Version})")">
  <Actions>
    <a class="btn btn-outline btn-sm" href="/admin/curricula">Back to curricula</a>
    <a class="btn btn-outline btn-sm" href="@($"/admin/curricula/{Id}")">Back to curriculum</a>
  </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
  <Alert Kind="success">@_statusMessage</Alert>
}

@if (!string.IsNullOrWhiteSpace(_actionError))
{
  <Alert Kind="danger">@_actionError</Alert>
}

<StatePanel IsLoading="_loading" IsEmpty="@(_curriculum is null)" EmptyTitle="Curriculum not found" EmptyBody="The selected curriculum could not be loaded." LoadError="@_loadError">
  @if (_curriculum is not null)
  {
    <div class="detail-card">
      <h3>Existing items</h3>
      <div class="table-container shadow">
        <table class="clinic-table">
          <thead>
            <tr>
              <th>EPA</th>
              <th>Required count</th>
              <th>Minimum level</th>
              <th>Per-stage minima</th>
              <th>Window months</th>
              <th>Weight</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            @foreach (var item in _curriculum.Items)
            {
              <tr>
                @if (_editingItemId == item.Id)
                {
                  <td>
                    <InputSelect class="form-select" TValue="int" @bind-Value="_itemModel.EpaId">
                      @foreach (var epa in AvailableEpas)
                      {
                        <option value="@epa.Id">@epa.Code - @epa.Title</option>
                      }
                    </InputSelect>
                  </td>
                  <td><InputNumber class="form-control" @bind-Value="_itemModel.RequiredCount" /></td>
                  <td><InputNumber class="form-control" @bind-Value="_itemModel.MinimumLevelOrder" /></td>
                  <td><InputText class="form-control" @bind-Value="_itemModel.MinimumLevelByStageJson" placeholder='{"1":2,"2":3}' /></td>
                  <td><InputNumber class="form-control" @bind-Value="_itemModel.WindowMonths" /></td>
                  <td><InputNumber class="form-control" @bind-Value="_itemModel.Weight" /></td>
                  <td>
                    <div class="actions-cell">
                      <button class="btn btn-sm btn-primary" @onclick="SaveItemAsync">Save</button>
                      <button class="btn btn-sm btn-outline" @onclick="CancelEdit">Cancel</button>
                    </div>
                  </td>
                }
                else
                {
                  <td>@item.EpaCode - @item.EpaTitle</td>
                  <td>@item.RequiredCount</td>
                  <td>@item.MinimumLevelOrder</td>
                  <td>@(item.MinimumLevelByStageJson ?? "—")</td>
                  <td>@item.WindowMonths</td>
                  <td>@(item.Weight?.ToString("0.##") ?? "—")</td>
                  <td>
                    <div class="actions-cell">
                      <button class="btn btn-sm btn-outline" @onclick="() => BeginEdit(item)">Edit</button>
                      <button class="btn btn-sm btn-danger" @onclick="() => RemoveItemAsync(item.Id)">Remove</button>
                    </div>
                  </td>
                }
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>

    <div class="form-container mt-3">
      <h3>Add item</h3>
      <EditForm Model="_itemModel" OnValidSubmit="AddItemAsync" FormName="curriculum-item">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary-errors" />

        <div class="form-grid form-grid--wide">
          <FormField Label="EPA" InputId="curriculum-item-epa" Required="true">
            <InputSelect id="curriculum-item-epa" class="form-select" TValue="int" @bind-Value="_itemModel.EpaId">
              @foreach (var epa in AvailableEpas)
              {
                <option value="@epa.Id">@epa.Code - @epa.Title</option>
              }
            </InputSelect>
          </FormField>

          <FormField Label="Required count" InputId="curriculum-item-count">
            <InputNumber id="curriculum-item-count" class="form-control" @bind-Value="_itemModel.RequiredCount" />
          </FormField>

          <FormField Label="Minimum level" InputId="curriculum-item-level">
            <InputNumber id="curriculum-item-level" class="form-control" @bind-Value="_itemModel.MinimumLevelOrder" />
          </FormField>

          <FormField Label="Per-stage minima (JSON)" InputId="curriculum-item-stage-levels" FullWidth="true">
            <InputText id="curriculum-item-stage-levels" class="form-control" @bind-Value="_itemModel.MinimumLevelByStageJson" placeholder='{"1":2,"2":3,"3":4}' />
            <small class="muted">Optional JSON object keyed by training year. Overrides the flat minimum level when the trainee is at that year.</small>
          </FormField>

          <FormField Label="Window months" InputId="curriculum-item-window">
            <InputNumber id="curriculum-item-window" class="form-control" @bind-Value="_itemModel.WindowMonths" />
          </FormField>

          <FormField Label="Weight" InputId="curriculum-item-weight">
            <InputNumber id="curriculum-item-weight" class="form-control" @bind-Value="_itemModel.Weight" />
          </FormField>
        </div>

        <FormActions>
          <button type="submit" class="btn btn-primary" disabled="@_saving">Add item</button>
        </FormActions>
      </EditForm>
    </div>
  }
</StatePanel>

@code {
  [Parameter]
  public int Id { get; set; }

  private CurriculumDto? _curriculum;
  private IReadOnlyList<EpaDto> _epas = [];
  private readonly CurriculumItemFormModel _itemModel = new();
  private int? _editingItemId;
  private string? _loadError;
  private string? _actionError;
  private string? _statusMessage;
  private bool _loading;
  private bool _saving;

  private IEnumerable<EpaDto> AvailableEpas => _epas.Where(entity => entity.SubSpecialityId == _curriculum?.SubSpecialityId);

  protected override async Task OnParametersSetAsync()
  {
    _loading = true;
    _loadError = null;
    _actionError = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _curriculum = await Sender.Send(new GetCurriculumByIdQuery(Id, authState.User));
      if (_curriculum is null)
      {
        Navigation.NavigateTo("/not-found");
        return;
      }

      _epas = await Sender.Send(new ListEpasForSubSpecialityQuery(_curriculum.SubSpecialityId, authState.User));
      ResetItemModel();
    }
    catch (Exception exception)
    {
      _loadError = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task AddItemAsync()
  {
    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    await RefreshCurriculumAsync(() => Sender.Send(new AddCurriculumItemCommand(Id, _itemModel.EpaId, _itemModel.RequiredCount, _itemModel.MinimumLevelOrder, _itemModel.WindowMonths, _itemModel.Weight, EmptyToNull(_itemModel.MinimumLevelByStageJson), authState.User)), "Curriculum item added.");
    ResetItemModel();
  }

  private void BeginEdit(CurriculumItemDto item)
  {
    _editingItemId = item.Id;
    _itemModel.EpaId = item.EpaId;
    _itemModel.RequiredCount = item.RequiredCount;
    _itemModel.MinimumLevelOrder = item.MinimumLevelOrder;
    _itemModel.WindowMonths = item.WindowMonths;
    _itemModel.Weight = item.Weight;
    _itemModel.MinimumLevelByStageJson = item.MinimumLevelByStageJson;
  }

  private void CancelEdit()
  {
    _editingItemId = null;
    ResetItemModel();
  }

  private async Task SaveItemAsync()
  {
    if (!_editingItemId.HasValue)
    {
      return;
    }

    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    await RefreshCurriculumAsync(() => Sender.Send(new UpdateCurriculumItemCommand(Id, _editingItemId.Value, _itemModel.EpaId, _itemModel.RequiredCount, _itemModel.MinimumLevelOrder, _itemModel.WindowMonths, _itemModel.Weight, EmptyToNull(_itemModel.MinimumLevelByStageJson), authState.User)), "Curriculum item saved.");
    _editingItemId = null;
    ResetItemModel();
  }

  private async Task RemoveItemAsync(int itemId)
  {
    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    await RefreshCurriculumAsync(() => Sender.Send(new RemoveCurriculumItemCommand(Id, itemId, authState.User)), "Curriculum item removed.");
  }

  private async Task RefreshCurriculumAsync(Func<Task<CurriculumDto>> action, string successMessage)
  {
    _saving = true;
    _actionError = null;
    _statusMessage = null;

    try
    {
      _curriculum = await action();
      _statusMessage = successMessage;
    }
    catch (Exception exception)
    {
      _actionError = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private void ResetItemModel()
  {
    _itemModel.EpaId = AvailableEpas.FirstOrDefault()?.Id ?? 0;
    _itemModel.RequiredCount = 1;
    _itemModel.MinimumLevelOrder = 4;
    _itemModel.WindowMonths = 12;
    _itemModel.Weight = null;
    _itemModel.MinimumLevelByStageJson = null;
  }

  private static string? EmptyToNull(string? value)
    => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

  private sealed class CurriculumItemFormModel
  {
    [Range(1, int.MaxValue)]
    public int EpaId { get; set; }

    [Range(1, int.MaxValue)]
    public int RequiredCount { get; set; }

    [Range(1, 20)]
    public int MinimumLevelOrder { get; set; }

    [Range(1, int.MaxValue)]
    public int WindowMonths { get; set; }

    public double? Weight { get; set; }

    [StringLength(1000)]
    public string? MinimumLevelByStageJson { get; set; }
  }
}
