@page "/admin/curricula/new"
@page "/admin/curricula/{Id:int}"
@attribute [Authorize(Policy = "AdministratorOrInstitutionalAdmin")]
@inject IScopedSender Sender
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(IsNew ? "Create Curriculum" : "Edit Curriculum")</PageTitle>

<PageHeader Title="@(IsNew ? "Create curriculum" : "Edit curriculum")" Subtitle="Set the scope, version window, and lifecycle of the curriculum.">
  <Actions>
    <a class="btn btn-outline btn-sm" href="/admin/curricula">Back to curricula</a>
    @if (!IsNew)
    {
      <a class="btn btn-outline btn-sm" href="@($"/admin/curricula/{Id}/items")">Manage items</a>
    }
  </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
  <Alert Kind="success">@_statusMessage</Alert>
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
  <Alert Kind="danger">@_errorMessage</Alert>
}

<StatePanel IsLoading="_loading" IsEmpty="false" EmptyTitle="" EmptyBody="">
  <div class="details-grid">
    <section class="detail-card">
      <h3>Curriculum details</h3>
      <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="curriculum-edit">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary-errors" />

        <div class="form-grid form-grid--wide">
          <FormField Label="Sub-speciality" InputId="curriculum-sub-speciality" Required="true">
            <InputSelect id="curriculum-sub-speciality" class="form-select" TValue="int" @bind-Value="_model.SubSpecialityId">
              @foreach (var option in SubSpecialityOptions)
              {
                <option value="@option.Id">@option.Label</option>
              }
            </InputSelect>
          </FormField>

          <FormField Label="Name" InputId="curriculum-name" Required="true">
            <InputText id="curriculum-name" class="form-control" @bind-Value="_model.Name" />
            <ValidationMessage For="() => _model.Name" />
          </FormField>

          <FormField Label="Version" InputId="curriculum-version" Required="true">
            <InputText id="curriculum-version" class="form-control" @bind-Value="_model.Version" />
            <ValidationMessage For="() => _model.Version" />
          </FormField>

          <FormField Label="Effective from" InputId="curriculum-effective-from">
            <InputDate id="curriculum-effective-from" class="form-control" @bind-Value="_model.EffectiveFrom" />
          </FormField>

          <FormField Label="Effective to" InputId="curriculum-effective-to">
            <InputDate id="curriculum-effective-to" class="form-control" TValue="DateOnly?" @bind-Value="_model.EffectiveTo" />
          </FormField>

          @if (!IsNew)
          {
            <FormField Label="Status" InputId="curriculum-active">
              <div class="form-check">
                <InputCheckbox id="curriculum-active" class="form-check-input" @bind-Value="_model.IsActive" />
                <label for="curriculum-active">Active</label>
              </div>
            </FormField>
          }
        </div>

        <FormActions>
          <a class="btn btn-outline" href="/admin/curricula">Cancel</a>
          <button type="submit" class="btn btn-primary" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
        </FormActions>
      </EditForm>
    </section>

    @if (!IsNew)
    {
      <aside class="detail-card">
        <h3>Clone as new version</h3>
        <EditForm Model="_cloneModel" OnValidSubmit="CloneAsync" FormName="curriculum-clone">
          <DataAnnotationsValidator />
          <ValidationSummary class="validation-summary-errors" />

          <div class="form-grid">
            <FormField Label="New version" InputId="clone-version" Required="true">
              <InputText id="clone-version" class="form-control" @bind-Value="_cloneModel.Version" />
              <ValidationMessage For="() => _cloneModel.Version" />
            </FormField>

            <FormField Label="Effective from" InputId="clone-effective-from">
              <InputDate id="clone-effective-from" class="form-control" @bind-Value="_cloneModel.EffectiveFrom" />
            </FormField>

            <FormField Label="Effective to" InputId="clone-effective-to">
              <InputDate id="clone-effective-to" class="form-control" TValue="DateOnly?" @bind-Value="_cloneModel.EffectiveTo" />
            </FormField>
          </div>

          <FormActions>
            <button type="submit" class="btn btn-outline" disabled="@_saving">Clone</button>
          </FormActions>
        </EditForm>
      </aside>
    }
  </div>
</StatePanel>

@code {
  [Parameter]
  public int? Id { get; set; }

  private readonly CurriculumFormModel _model = new();
  private readonly CloneCurriculumModel _cloneModel = new();
  private IReadOnlyList<InstitutionDto> _institutions = [];
  private IReadOnlyList<SpecialityDto> _specialities = [];
  private IReadOnlyList<SubSpecialityDto> _subSpecialities = [];
  private string? _errorMessage;
  private string? _statusMessage;
  private bool _loading;
  private bool _saving;

  private bool IsNew => !Id.HasValue;

  private IEnumerable<LookupOption> SubSpecialityOptions =>
    from subSpeciality in _subSpecialities
    join speciality in _specialities on subSpeciality.SpecialityId equals speciality.Id
    join institution in _institutions on speciality.InstitutionId equals institution.Id
    select new LookupOption(subSpeciality.Id, $"{institution.Name} / {speciality.Name} / {subSpeciality.Name}");

  protected override async Task OnParametersSetAsync()
  {
    _loading = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _institutions = await Sender.Send(new GetInstitutionsListQuery(authState.User));
      _specialities = await Sender.Send(new GetSpecialitiesListQuery(authState.User));
      _subSpecialities = await Sender.Send(new GetSubSpecialitiesListQuery(authState.User));

      if (IsNew)
      {
        _model.SubSpecialityId = _subSpecialities.FirstOrDefault()?.Id ?? 0;
        _model.EffectiveFrom = DateOnly.FromDateTime(DateTime.Today);
        _model.IsActive = true;
        _cloneModel.EffectiveFrom = DateOnly.FromDateTime(DateTime.Today);
        return;
      }

      var curriculum = await Sender.Send(new GetCurriculumByIdQuery(Id!.Value, authState.User));

      if (curriculum is null)
      {
        Navigation.NavigateTo("/not-found");
        return;
      }

      _model.SubSpecialityId = curriculum.SubSpecialityId;
      _model.Name = curriculum.Name;
      _model.Version = curriculum.Version;
      _model.EffectiveFrom = curriculum.EffectiveFrom;
      _model.EffectiveTo = curriculum.EffectiveTo;
      _model.IsActive = curriculum.IsActive;

      _cloneModel.Version = $"{curriculum.Version}-copy";
      _cloneModel.EffectiveFrom = curriculum.EffectiveFrom.AddDays(1);
      _cloneModel.EffectiveTo = curriculum.EffectiveTo;
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task SaveAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      CurriculumDto curriculum;

      if (IsNew)
      {
        curriculum = await Sender.Send(new CreateCurriculumCommand(_model.SubSpecialityId, _model.Name, _model.Version, _model.EffectiveFrom, _model.EffectiveTo, authState.User));
        Navigation.NavigateTo($"/admin/curricula/{curriculum.Id}", forceLoad: true);
        return;
      }

      curriculum = await Sender.Send(new UpdateCurriculumCommand(Id!.Value, _model.SubSpecialityId, _model.Name, _model.Version, _model.EffectiveFrom, _model.EffectiveTo, _model.IsActive, authState.User));
      _model.IsActive = curriculum.IsActive;
      _statusMessage = "Curriculum saved.";
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private async Task CloneAsync()
  {
    _saving = true;
    _errorMessage = null;
    _statusMessage = null;

    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      var cloned = await Sender.Send(new CloneCurriculumAsNewVersionCommand(Id!.Value, _cloneModel.Version, _cloneModel.EffectiveFrom, _cloneModel.EffectiveTo, authState.User));
      Navigation.NavigateTo($"/admin/curricula/{cloned.Id}", forceLoad: true);
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
    finally
    {
      _saving = false;
    }
  }

  private sealed class CurriculumFormModel
  {
    [Range(1, int.MaxValue)]
    public int SubSpecialityId { get; set; }

    [Required]
    [StringLength(200)]
    public string Name { get; set; } = string.Empty;

    [Required]
    [StringLength(64)]
    public string Version { get; set; } = string.Empty;

    public DateOnly EffectiveFrom { get; set; }
    public DateOnly? EffectiveTo { get; set; }
    public bool IsActive { get; set; } = true;
  }

  private sealed class CloneCurriculumModel
  {
    [Required]
    [StringLength(64)]
    public string Version { get; set; } = string.Empty;

    public DateOnly EffectiveFrom { get; set; }
    public DateOnly? EffectiveTo { get; set; }
  }

  private sealed record LookupOption(int Id, string Label);
}
