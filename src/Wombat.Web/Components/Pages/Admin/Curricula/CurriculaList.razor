@page "/admin/curricula"
@attribute [Authorize(Policy = "NationalCatalogueAccess")]
@inject IScopedSender Sender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Curricula</PageTitle>

<PageHeader Title="Curricula" Subtitle="Manage curriculum versions and the sub-speciality they apply to.">
  <Actions>
    <a class="btn btn-primary" href="/admin/curricula/new">
      <Icon Name="plus" />
      Create curriculum
    </a>
  </Actions>
</PageHeader>

<StatePanel IsLoading="@(_curricula is null || _subSpecialities is null || _specialities is null || _institutions is null)" LoadError="@_errorMessage" IsEmpty="@(_curricula?.Count == 0)" EmptyTitle="No curricula yet" EmptyBody="Create a curriculum before admitting trainees or building progress rules.">
  @if (_curricula is not null && _subSpecialities is not null && _specialities is not null && _institutions is not null)
  {
    <DataTable TItem="CurriculumDto" Items="_curricula" Caption="Curricula">
      <HeaderRow>
        <tr>
          <th>Name</th>
          <th>Version</th>
          <th>Institution</th>
          <th>Speciality</th>
          <th>Sub-speciality</th>
          <th>Effective</th>
          <th>Items</th>
          <th>Status</th>
          <th></th>
        </tr>
      </HeaderRow>
      <Row Context="curriculum">
        @{
          var subSpeciality = _subSpecialities.Single(entity => entity.Id == curriculum.SubSpecialityId);
          var speciality = _specialities.Single(entity => entity.Id == subSpeciality.SpecialityId);
        }
        <tr>
          <td>@curriculum.Name</td>
          <td>@curriculum.Version</td>
          @* Curricula are national now (T091); College column lands with the Phase 5 admin rework. *@
          <td>—</td>
          <td>@speciality.Name</td>
          <td>@subSpeciality.Name</td>
          <td>@curriculum.EffectiveFrom.ToString("yyyy-MM-dd")</td>
          <td>@curriculum.Items.Count</td>
          <td>@(curriculum.IsActive ? "Active" : "Inactive")</td>
          <td>
            <div class="actions-cell">
              <a class="btn btn-outline btn-sm" href="@($"/admin/curricula/{curriculum.Id}")">Edit</a>
              <a class="btn btn-outline btn-sm" href="@($"/admin/curricula/{curriculum.Id}/items")">Items</a>
            </div>
          </td>
        </tr>
      </Row>
    </DataTable>
  }
</StatePanel>

@code {
  private IReadOnlyList<CurriculumDto>? _curricula;
  private IReadOnlyList<InstitutionDto>? _institutions;
  private IReadOnlyList<SpecialityDto>? _specialities;
  private IReadOnlyList<SubSpecialityDto>? _subSpecialities;
  private string? _errorMessage;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
      _curricula = await Sender.Send(new GetCurriculaListQuery(authState.User));
      _institutions = await Sender.Send(new GetInstitutionsListQuery(authState.User));
      _specialities = await Sender.Send(new GetSpecialitiesListQuery(authState.User));
      _subSpecialities = await Sender.Send(new GetSubSpecialitiesListQuery(authState.User));
    }
    catch (Exception exception)
    {
      _errorMessage = exception.Message;
    }
  }
}
